<script data-picker="injected">
(function () {
  'use strict';

  // Singleton guard: exit immediately if already executed.
  if (window.__COLOSSUS_PICKER_LOADED__) return;

  // Capability-Aware Progressive Enhancement.
  // <meta name="colossus-annotate" content="annotate,plan"> declares which
  // capabilities the host page handles natively (comma-separated list).
  // overlay.js skips those capabilities but still injects any it owns — so
  // feedbackBtn always appears on Colossus pages even though AnnotateButton
  // is rendered by the React shell. If BOTH annotate AND feedback are listed,
  // overlay.js has nothing to add and exits entirely.
  var _metaEl = document.querySelector('meta[name="colossus-annotate"]');
  var _nativeCaps = {};
  if (_metaEl) {
    var _capsList = (_metaEl.getAttribute('content') || '').split(',');
    for (var _ci = 0; _ci < _capsList.length; _ci++) {
      var _cap = _capsList[_ci].trim();
      if (_cap) _nativeCaps[_cap] = true;
    }
  }
  if (_nativeCaps['annotate'] && _nativeCaps['feedback']) return;
  window.__COLOSSUS_PICKER_LOADED__ = true;
  // True when the host page has a native annotation widget — annotateBtn stays
  // in the DOM (so all state-machine references remain valid) but is never shown.
  var _nativeAnnotate = !!_nativeCaps['annotate'];

  var MOCKUP_ID = '35b669ae-38c1-4bfc-ae64-5acefc3f7f36';
  var ANNOTATE_URL = 'https://mockups.athenconsult.com/annotate';
  // In deployment mode getOverlayJs() replaces this placeholder with the real token.
  // When the placeholder survives (token === sentinel below), the picker is running
  // inside the mockup BFF and should use the original batches payload format.
  var ANNOTATE_TOKEN = '__ANNOTATE_TOKEN__';
  // Widget mode controls which buttons are shown:
  //   'all'           — both Annotate and Feedback buttons visible
  //   'fix-only'      — only Annotate button visible
  //   'feedback-only' — only Feedback button visible
  // Injected by getOverlayJs(); defaults to 'all' (shows everything).
  var WIDGET_MODE = '__WIDGET_MODE__';
  // Feedback endpoint URL — injected by getOverlayJs() for deployments.
  // Empty string in mockup/team mode; feedback button is hidden when empty.
  var FEEDBACK_URL = '__FEEDBACK_URL__';
  // Status poll URL — injected by getOverlayJs() for deployments and team previews.
  // In mockup mode (sentinel survives) it is derived at runtime from ANNOTATE_URL.
  var STATUS_URL = '__STATUS_URL__';
  if (STATUS_URL === '__STATUS_URL__') {
    // Mockup mode: status served by mockup_server.py at /status?id=<mockup_id>
    STATUS_URL = ANNOTATE_URL.replace('/annotate', '/status') + '?id=' + MOCKUP_ID;
  }

  // ── State machine ─────────────────────────────────────────────────────────

  var state = 'IDLE';
  var pendingSelections = [];   // array of capturedData objects (with _el reference)
  var batchItems = [];          // array of { feedback, elements: [...capturedData without _el] }
  var feedbackIsGeneral = false;
  var feedbackResearch = false;
  var pendingAttachments = [];  // array of AttachmentItem uploaded before submit
  var attachmentUploading = false;
  // Memento for revert-on-cancel: snapshot of a queued item currently being edited.
  // Shape: { item: <deep-cloned batch item>, index: <number> } or null when not editing.
  var editingOriginal = null;

  // ── Blur-lock: processing state while AI agent works ─────────────────────
  // When an annotation is submitted the selected elements are visually locked
  // (a blurred overlay covers them) until the status endpoint signals
  // build_ready AND its revision advances past the value captured at submit.
  //
  // The lock survives both SPA route changes and full reloads because the set
  // of locked CSS selectors is persisted to sessionStorage. Rather than mutate
  // the target element's own inline styles (which are lost when Angular replaces
  // the node on re-render), an absolutely-positioned overlay <div> is drawn over
  // each matching element and continuously re-attached/repositioned.

  var _BLUR_LOCK_KEY = 'pk-blur-lock-' + MOCKUP_ID;
  var _blurOverlays = [];         // overlay <div> nodes currently rendered
  var _blurPollTimer = null;
  var _blurTimeoutTimer = null;
  var _blurReapplyTimer = null;   // debounce handle for MutationObserver-driven re-apply
  var _blurRepositionRAF = null;  // rAF handle for scroll/resize repositioning
  var revisionAtSubmit = 0;       // /status revision at submit time (Change 3)

  function _readBlurLock() {
    try {
      var raw = sessionStorage.getItem(_BLUR_LOCK_KEY);
      if (!raw) return null;
      var rec = JSON.parse(raw);
      if (!rec || !rec.selectors || !rec.selectors.length) return null;
      return rec;
    } catch (ex) { return null; }
  }

  function _writeBlurLock(selectors, revision) {
    try {
      sessionStorage.setItem(_BLUR_LOCK_KEY, JSON.stringify({
        selectors: selectors || [],
        revisionAtSubmit: typeof revision === 'number' ? revision : 0,
        ts: Date.now(),
      }));
    } catch (ex) {}
  }

  function _makeBlurOverlay() {
    var ov = document.createElement('div');
    ov.setAttribute('data-picker-ui', 'true');
    ov.style.cssText = [
      'position:absolute',
      'backdrop-filter:blur(6px)',
      '-webkit-backdrop-filter:blur(6px)',
      'background:rgba(255,255,255,.45)',
      'border:2px dashed #6366f1',
      'border-radius:6px',
      'z-index:99998',
      'pointer-events:auto',
      'display:flex',
      'align-items:center',
      'justify-content:center',
      'font:600 12px/1 system-ui,sans-serif',
      'color:#6366f1',
    ].join(';');
    ov.textContent = '🤖 updating…';
    return ov;
  }

  function _positionBlurOverlay(ov, target) {
    try {
      var rect = target.getBoundingClientRect();
      ov.style.left   = (rect.left + window.scrollX) + 'px';
      ov.style.top    = (rect.top  + window.scrollY) + 'px';
      ov.style.width  = rect.width  + 'px';
      ov.style.height = rect.height + 'px';
    } catch (ex) {}
  }

  // Rebuild overlays from the persisted lock record. Idempotent — clears any
  // existing overlays first, then re-draws one per currently-matching selector.
  // Called on init, on SPA route change, from a debounced MutationObserver, and
  // (for repositioning) on scroll/resize.
  function _reapplyLockOverlays() {
    var rec = _readBlurLock();
    // Remove any overlay nodes from a previous pass before redrawing.
    for (var i = 0; i < _blurOverlays.length; i++) {
      try { if (_blurOverlays[i].parentNode) _blurOverlays[i].parentNode.removeChild(_blurOverlays[i]); } catch (ex) {}
    }
    _blurOverlays = [];
    if (!rec) return;
    if (typeof rec.revisionAtSubmit === 'number') revisionAtSubmit = rec.revisionAtSubmit;

    for (var s = 0; s < rec.selectors.length; s++) {
      var sel = rec.selectors[s];
      var target;
      try { target = document.querySelector(sel); } catch (ex) { target = null; }
      if (!target) continue;
      var ov = _makeBlurOverlay();
      _positionBlurOverlay(ov, target);
      ov._blurTarget = target;
      try { document.body.appendChild(ov); } catch (ex) { continue; }
      _blurOverlays.push(ov);
    }
  }

  function _repositionLockOverlays() {
    for (var i = 0; i < _blurOverlays.length; i++) {
      var ov = _blurOverlays[i];
      if (ov && ov._blurTarget && document.contains(ov._blurTarget)) {
        _positionBlurOverlay(ov, ov._blurTarget);
      }
    }
  }

  function _clearLockOverlays() {
    for (var i = 0; i < _blurOverlays.length; i++) {
      try { if (_blurOverlays[i].parentNode) _blurOverlays[i].parentNode.removeChild(_blurOverlays[i]); } catch (ex) {}
    }
    _blurOverlays = [];
    try { sessionStorage.removeItem(_BLUR_LOCK_KEY); } catch (ex) {}
  }

  // ── Backwards-compatible shims ────────────────────────────────────────────
  // Callers still reference these by name; reimplement on top of the overlay +
  // sessionStorage approach so no inline styles are ever applied to targets.
  var _blurLockedEls = [];  // retained for reference; overlays live in _blurOverlays

  // Persist a single selector into the lock record then re-render overlays.
  function _blurLockEl(el) {
    if (!el) return;
    var sel = null;
    try { sel = buildSelector(el); } catch (ex) { sel = null; }
    if (!sel) return;
    var rec = _readBlurLock();
    var selectors = rec ? rec.selectors.slice() : [];
    if (selectors.indexOf(sel) === -1) selectors.push(sel);
    _writeBlurLock(selectors, rec ? rec.revisionAtSubmit : revisionAtSubmit);
    _reapplyLockOverlays();
  }

  function _blurUnlockAll() {
    _clearLockOverlays();
  }

  function _stopBlurPoll() {
    if (_blurPollTimer)   { clearInterval(_blurPollTimer);   _blurPollTimer   = null; }
    if (_blurTimeoutTimer){ clearTimeout(_blurTimeoutTimer); _blurTimeoutTimer = null; }
  }

  // Inject a small "🔄 Reload now" button into statusMsg the user can click to
  // force a reload while waiting. Idempotent — only one button per statusMsg.
  function _ensureManualReloadBtn() {
    if (document.getElementById('pk-manual-reload-btn')) return;
    var btn = document.createElement('button');
    btn.id = 'pk-manual-reload-btn';
    btn.setAttribute('data-picker-ui', 'true');
    btn.textContent = '🔄 Reload now';
    btn.style.cssText = 'margin-top:6px;padding:5px 12px;background:#6366f1;color:#fff;border:none;border-radius:6px;font-size:12px;cursor:pointer;display:block;';
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      window.location.reload();
    });
    try { statusMsg.appendChild(btn); } catch (ex) {}
  }

  function _startBlurPoll() {
    var _started = Date.now();
    _blurPollTimer = setInterval(function () {
      fetch(STATUS_URL, { cache: 'no-store' })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (!d) return;
          var revision = d.revision;
          if (d.annotationStatus === 'build_ready' &&
              typeof revision === 'number' && revision > revisionAtSubmit) {
            _stopBlurPoll();
            _clearLockOverlays();
            // Bust caches: append a version param so the browser re-fetches the
            // freshly-built page rather than serving the stale cached response.
            var sep = location.search ? location.search + '&' : '?';
            var dest = location.pathname + sep + 'v=' + revision + (location.hash || '');
            window.location.href = dest;
          }
        })
        .catch(function () { /* transient network error — keep polling */ });
    }, 2000);

    // At ~90 s: keep the lock in place but tell the user it's taking longer and
    // expose a manual reload button. The lock is NEVER silently cleared here —
    // that previously left stale content with no visible indication of state.
    _blurTimeoutTimer = setTimeout(function () {
      statusMsg.textContent = '🤖 Still building… (taking longer than usual)';
      statusMsg.style.display = 'block';
      _ensureManualReloadBtn();
    }, 90000);

    // Hard 300 s cap: stop polling, clear the lock, and surface a timeout
    // message. The manual reload button remains available.
    setTimeout(function () {
      if (Date.now() - _started < 299000) return; // poll was already stopped
      _stopBlurPoll();
      _clearLockOverlays();
      statusMsg.textContent = '⚠️ Build timed out — reload to check.';
      statusMsg.style.display = 'block';
      _ensureManualReloadBtn();
    }, 300000);
  }

  // ── Re-apply the lock across navigation ───────────────────────────────────
  // Mirrors the existing 'pk-paused-selections' persistence pattern (see the
  // beforeunload block) with the same defensive try/catch style.

  // 2) SPA route change — monkey-patch history.pushState / replaceState to emit
  //    a custom event, and listen for popstate. Angular Router uses the History
  //    API for client-side navigation, so this fires on every route change.
  try {
    (function () {
      var _emit = function () {
        try { window.dispatchEvent(new Event('pk-locationchange')); } catch (ex) {}
      };
      var _origPush = history.pushState;
      var _origReplace = history.replaceState;
      history.pushState = function () {
        var r = _origPush.apply(this, arguments);
        _emit();
        return r;
      };
      history.replaceState = function () {
        var r = _origReplace.apply(this, arguments);
        _emit();
        return r;
      };
      window.addEventListener('popstate', _emit);
      window.addEventListener('pk-locationchange', function () { _reapplyLockOverlays(); });
    })();
  } catch (ex) {}

  // 3) Angular re-renders replace DOM nodes asynchronously after navigation, so
  //    watch document.body and re-apply (debounced) whenever the subtree changes.
  try {
    new MutationObserver(function () {
      if (!_readBlurLock()) return; // nothing locked — skip the work
      if (_blurReapplyTimer) clearTimeout(_blurReapplyTimer);
      _blurReapplyTimer = setTimeout(_reapplyLockOverlays, 200);
    }).observe(document.body, { childList: true, subtree: true });
  } catch (ex) {}

  // 4) Reposition existing overlays on scroll/resize (rAF-debounced).
  function _scheduleReposition() {
    if (!_blurOverlays.length) return;
    if (_blurRepositionRAF) return;
    _blurRepositionRAF = requestAnimationFrame(function () {
      _blurRepositionRAF = null;
      _repositionLockOverlays();
    });
  }
  window.addEventListener('scroll', _scheduleReposition, true);
  window.addEventListener('resize', _scheduleReposition);

  // 1) On script init, restore any lock left over from before a full reload.
  try { _reapplyLockOverlays(); } catch (ex) {}
  // ── End blur-lock ─────────────────────────────────────────────────────────
  var hoveredEl = null;
  var stackElements = [];
  var stackHighlightedEl = null;

  // ── Feature 1: Click debounce state ───────────────────────────────────────

  var clickCount = 0;
  var lastClickPoint = null;
  var clickTimer = null;
  var previewEl = null;

  // ── Feature 2: Long-press state ───────────────────────────────────────────

  var longPressTimer = null;
  var longPressPoint = null;
  var longPressFired = false;

  // ── Feature 3: Browse state ───────────────────────────────────────────────

  var browseCache = null;
  var browseHoverEl = null;

  // ── Shake animation ───────────────────────────────────────────────────────

  var shakeStyle = document.createElement('style');
  shakeStyle.textContent = '@keyframes pk-shake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-4px)}40%,80%{transform:translateX(4px)}}';
  document.head.appendChild(shakeStyle);

  // ── Annotate corner button ────────────────────────────────────────────────

  var annotateBtn = document.createElement('button');
  annotateBtn.setAttribute('data-picker-ui', 'true');
  annotateBtn.textContent = '✏️ Annotate';
  annotateBtn.style.cssText = [
    'position:fixed',
    'bottom:16px',
    'right:16px',
    'z-index:99999',
    'padding:9px 18px',
    'background:#6366f1',
    'color:#fff',
    'border:none',
    'border-radius:24px',
    'font:600 13px/1 system-ui,sans-serif',
    'cursor:grab',
    'box-shadow:0 4px 14px rgba(99,102,241,.45)',
    'touch-action:none',  // required: tells browser we own this touch, prevents scroll interference
  ].join(';');
  document.body.appendChild(annotateBtn);

  // ── Feedback corner button ────────────────────────────────────────────────
  // Launches the same selection flow as annotateBtn but posts to FEEDBACK_URL.
  // Stacked above annotateBtn (bottom:72px) in the same corner; independently draggable.
  // Visible in 'all' and 'feedback-only' modes; hidden when FEEDBACK_URL is empty.

  var feedbackBtn = document.createElement('button');
  feedbackBtn.setAttribute('data-picker-ui', 'true');
  feedbackBtn.textContent = '💬 Feedback';
  feedbackBtn.style.cssText = [
    'position:fixed',
    'bottom:72px',
    'right:16px',
    'z-index:99999',
    'padding:9px 18px',
    'background:#10b981',
    'color:#fff',
    'border:none',
    'border-radius:24px',
    'font:600 13px/1 system-ui,sans-serif',
    'cursor:grab',
    'box-shadow:0 4px 14px rgba(16,185,129,.45)',
    'touch-action:none',  // required: tells browser we own this touch, prevents scroll interference
  ].join(';');
  document.body.appendChild(feedbackBtn);

  // ── Widget mode — init-time visibility ────────────────────────────────────
  // Applied immediately after both buttons exist in the DOM.

  // Normalize: treat sentinel (unreplaced placeholder) as 'all'
  var _resolvedMode = (WIDGET_MODE && WIDGET_MODE !== '__WIDGET_MODE__') ? WIDGET_MODE : 'all';
  var _hasFeedbackUrl = FEEDBACK_URL && FEEDBACK_URL !== '__FEEDBACK_URL__' && FEEDBACK_URL !== '';

  if (_resolvedMode === 'feedback-only' || _nativeAnnotate) {
    annotateBtn.style.display = 'none';
  }
  if (_resolvedMode === 'fix-only' || !_hasFeedbackUrl) {
    feedbackBtn.style.display = 'none';
  }

  // ── Session config objects (strategy pattern) ─────────────────────────────
  // Each config binds a FAB element to its idle label and color.
  // _sessionConfig is set when a FAB is clicked; transitionTo() reads it instead
  // of hardcoding annotateBtn — enabling feedbackBtn to own Cancel/Resume states.
  // _activeBtn tracks which FAB opened the current session; _repositionPanel anchors to it.

  var ANNOTATE_CONFIG = { btn: annotateBtn, idleLabel: '✏️ Annotate', idleColor: '#6366f1' };
  var FEEDBACK_CONFIG = { btn: feedbackBtn, idleLabel: '💬 Feedback',  idleColor: '#10b981' };
  var _sessionConfig  = ANNOTATE_CONFIG;
  var _activeBtn      = annotateBtn;

  // ── Overlay panel ─────────────────────────────────────────────────────────

  var overlay = document.createElement('div');
  overlay.setAttribute('data-picker-ui', 'true');
  overlay.style.cssText = [
    'position:fixed',
    'bottom:80px',
    'right:16px',
    'width:340px',
    'max-height:calc(100vh - 120px)',
    'overflow:hidden',
    'display:flex',
    'flex-direction:column',
    'z-index:99999',
    'background:#1e1e2e',
    'color:#f5f5f7',
    'border:1px solid #333',
    'border-radius:12px',
    'padding:0 16px 16px 16px',
    'font-family:system-ui,sans-serif',
    'font-size:13px',
    'box-shadow:0 8px 32px rgba(0,0,0,.5)',
    'display:none',
  ].join(';');
  document.body.appendChild(overlay);

  // ── Section: SELECTING ────────────────────────────────────────────────────

  var selectingSection = document.createElement('div');
  selectingSection.id = 'pk-selecting-section';
  selectingSection.setAttribute('data-picker-ui', 'true');
  selectingSection.style.display = 'none';

  var selectingHint = document.createElement('div');
  selectingHint.setAttribute('data-picker-ui', 'true');
  selectingHint.style.cssText = 'font-size:11px;color:#64748b;margin-bottom:10px';
  selectingHint.textContent = 'Click elements to select. Click again to remove.';

  var selList = document.createElement('div');
  selList.id = 'pk-sel-list';
  selList.setAttribute('data-picker-ui', 'true');
  selList.style.cssText = 'flex:1;min-height:0;overflow-y:auto;';

  // Feature 3: Browse all elements button
  var browseBtn = document.createElement('button');
  browseBtn.id = 'pk-browse-btn';
  browseBtn.setAttribute('data-picker-ui', 'true');
  browseBtn.textContent = 'Browse all elements';
  browseBtn.style.cssText = 'width:100%;background:#334155;color:#fff;border:none;border-radius:8px;padding:7px 14px;font-size:13px;cursor:pointer;margin-bottom:8px;flex-shrink:0;';

  var selectingBtnRow = document.createElement('div');
  selectingBtnRow.setAttribute('data-picker-ui', 'true');
  selectingBtnRow.style.cssText = 'margin-top:10px;display:flex;gap:8px;flex-shrink:0;';

  var addFeedbackBtn = document.createElement('button');
  addFeedbackBtn.id = 'pk-add-feedback-btn';
  addFeedbackBtn.setAttribute('data-picker-ui', 'true');
  addFeedbackBtn.textContent = 'Add feedback →';
  addFeedbackBtn.style.cssText = 'padding:7px 14px;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:13px;cursor:pointer;';

  var generalNoteBtn = document.createElement('button');
  generalNoteBtn.id = 'pk-general-note-btn';
  generalNoteBtn.setAttribute('data-picker-ui', 'true');
  generalNoteBtn.textContent = '＋ General note';
  generalNoteBtn.style.cssText = 'padding:7px 14px;background:#334155;color:#f5f5f7;border:none;border-radius:8px;font-size:13px;cursor:pointer;';

  var selCancelBtn = document.createElement('button');
  selCancelBtn.id = 'pk-sel-cancel-btn';
  selCancelBtn.setAttribute('data-picker-ui', 'true');
  selCancelBtn.textContent = 'Cancel';
  selCancelBtn.style.cssText = 'padding:7px 14px;background:#475569;color:#fff;border:none;border-radius:8px;font-size:13px;cursor:pointer;';

  // ── Pause navigation button ───────────────────────────────────────────────
  // Suspends click capture so the user can navigate to another page, then
  // resume selection there. pendingSelections survives SPA route changes
  // because it lives in the JS closure; sessionStorage catches full reloads.
  var pauseNavBtn = document.createElement('button');
  pauseNavBtn.id = 'pk-pause-nav-btn';
  pauseNavBtn.setAttribute('data-picker-ui', 'true');
  pauseNavBtn.textContent = '⏸ Pause — navigate to another page';
  pauseNavBtn.style.cssText = 'width:100%;background:#1e3a5f;color:#93c5fd;border:1px solid #2d5a8e;border-radius:8px;padding:7px 14px;font-size:13px;cursor:pointer;margin-bottom:8px;flex-shrink:0;';

  selectingBtnRow.appendChild(addFeedbackBtn);
  selectingBtnRow.appendChild(generalNoteBtn);
  selectingBtnRow.appendChild(selCancelBtn);
  selectingSection.appendChild(selectingHint);
  selectingSection.appendChild(selList);
  selectingSection.appendChild(browseBtn);
  selectingSection.appendChild(pauseNavBtn);
  selectingSection.appendChild(selectingBtnRow);
  overlay.appendChild(selectingSection);

  // ── Section: STACK_NAV ────────────────────────────────────────────────────

  var stackNavSection = document.createElement('div');
  stackNavSection.id = 'pk-stacknav-section';
  stackNavSection.setAttribute('data-picker-ui', 'true');
  stackNavSection.style.display = 'none';

  var stackNavTitle = document.createElement('div');
  stackNavTitle.setAttribute('data-picker-ui', 'true');
  stackNavTitle.style.cssText = 'font-size:11px;color:#64748b;margin-bottom:6px';

  var stackList = document.createElement('ul');
  stackList.id = 'pk-stack-list';
  stackList.setAttribute('data-picker-ui', 'true');
  stackList.style.cssText = 'list-style:none;margin:0 0 8px 0;padding:0;';

  var stackBackBtn = document.createElement('button');
  stackBackBtn.id = 'pk-stack-back-btn';
  stackBackBtn.setAttribute('data-picker-ui', 'true');
  stackBackBtn.textContent = '← Back';
  stackBackBtn.style.cssText = 'padding:7px 14px;background:#475569;color:#fff;border:none;border-radius:8px;font-size:13px;cursor:pointer;';

  stackNavSection.appendChild(stackNavTitle);
  stackNavSection.appendChild(stackList);
  stackNavSection.appendChild(stackBackBtn);
  overlay.appendChild(stackNavSection);

  // ── Section: FEEDBACK ─────────────────────────────────────────────────────

  var feedbackSection = document.createElement('div');
  feedbackSection.id = 'pk-feedback-section';
  feedbackSection.setAttribute('data-picker-ui', 'true');
  feedbackSection.style.display = 'none';

  var feedbackSummary = document.createElement('div');
  feedbackSummary.id = 'pk-feedback-summary';
  feedbackSummary.setAttribute('data-picker-ui', 'true');
  feedbackSummary.style.cssText = 'font-size:11px;color:#94a3b8;margin-bottom:8px';

  var feedbackTextarea = document.createElement('textarea');
  feedbackTextarea.id = 'pk-feedback-textarea';
  feedbackTextarea.setAttribute('data-picker-ui', 'true');
  feedbackTextarea.placeholder = 'What should change about these elements?';
  feedbackTextarea.style.cssText = [
    'width:100%',
    'box-sizing:border-box',
    'height:80px',
    'background:#2a2a3e',
    'color:#f5f5f7',
    'border:1px solid #444',
    'border-radius:8px',
    'padding:8px 10px',
    'font-size:13px',
    'font-family:system-ui,sans-serif',
    'resize:vertical',
    'margin-bottom:10px',
  ].join(';');

  var researchRow = document.createElement('div');
  researchRow.setAttribute('data-picker-ui', 'true');
  researchRow.style.cssText = 'display:flex;align-items:center;gap:8px;margin-bottom:10px;cursor:pointer;';

  var researchCheckbox = document.createElement('input');
  researchCheckbox.type = 'checkbox';
  researchCheckbox.id = 'pk-research-checkbox';
  researchCheckbox.setAttribute('data-picker-ui', 'true');
  researchCheckbox.style.cssText = 'width:14px;height:14px;cursor:pointer;accent-color:#6366f1;';

  var researchLabel = document.createElement('label');
  researchLabel.setAttribute('for', 'pk-research-checkbox');
  researchLabel.setAttribute('data-picker-ui', 'true');
  researchLabel.textContent = '🔍 Research this feedback before applying';
  researchLabel.style.cssText = 'font-size:12px;color:#94a3b8;cursor:pointer;user-select:none;';

  researchRow.appendChild(researchCheckbox);
  researchRow.appendChild(researchLabel);

  researchCheckbox.addEventListener('change', function() {
    feedbackResearch = this.checked;
    researchLabel.style.color = this.checked ? '#6366f1' : '#94a3b8';
  });
  researchRow.addEventListener('click', function(e) {
    if (e.target !== researchCheckbox) {
      researchCheckbox.checked = !researchCheckbox.checked;
      researchCheckbox.dispatchEvent(new Event('change'));
    }
  });

  // ── Attachment drop zone (feedback section only) ──────────────────────────

  var attachChipsContainer = document.createElement('div');
  attachChipsContainer.setAttribute('data-picker-ui', 'true');
  attachChipsContainer.setAttribute('id', 'pk-attach-list');
  attachChipsContainer.style.cssText = 'display:none;margin-bottom:6px;';

  var attachDropZone = document.createElement('div');
  attachDropZone.setAttribute('data-picker-ui', 'true');
  attachDropZone.style.cssText = [
    'border:1px dashed #475569',
    'border-radius:8px',
    'padding:8px 10px',
    'margin-bottom:8px',
    'font-size:12px',
    'color:#94a3b8',
    'cursor:pointer',
    'text-align:center',
    'user-select:none',
    'transition:border-color .15s,color .15s',
  ].join(';');
  attachDropZone.textContent = '📎 Drop files or click to attach (max 10 MB)';

  var attachFileInput = document.createElement('input');
  attachFileInput.type = 'file';
  attachFileInput.multiple = true;
  attachFileInput.accept = 'image/*,application/pdf,text/*';
  attachFileInput.setAttribute('data-picker-ui', 'true');
  attachFileInput.style.display = 'none';

  function humanAttachSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return Math.round(bytes / 1024) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  function renderAttachChips() {
    attachChipsContainer.innerHTML = '';
    if (pendingAttachments.length === 0) {
      attachChipsContainer.style.display = 'none';
      return;
    }
    attachChipsContainer.style.display = 'block';

    // Header label
    var header = document.createElement('div');
    header.setAttribute('data-picker-ui', 'true');
    header.style.cssText = 'font-size:11px;color:#64748b;margin-bottom:4px;user-select:none;';
    header.textContent = '📎 Attached (' + pendingAttachments.length + '):';
    attachChipsContainer.appendChild(header);

    // One row per file
    pendingAttachments.forEach(function(att, i) {
      var row = document.createElement('div');
      row.setAttribute('data-picker-ui', 'true');
      row.setAttribute('data-attach-name', att.name);
      row.style.cssText = [
        'display:flex',
        'align-items:center',
        'gap:6px',
        'background:rgba(99,102,241,.1)',
        'border:1px solid rgba(99,102,241,.3)',
        'border-radius:6px',
        'padding:4px 8px',
        'margin-bottom:3px',
        'font-size:12px',
        'color:#c4c4d4',
      ].join(';');

      var icon = document.createElement('span');
      icon.setAttribute('data-picker-ui', 'true');
      icon.textContent = '📄';
      icon.style.cssText = 'flex-shrink:0;font-size:13px;';

      var nameSpan = document.createElement('span');
      nameSpan.setAttribute('data-picker-ui', 'true');
      nameSpan.textContent = att.name.length > 28 ? att.name.slice(0, 28) + '…' : att.name;
      nameSpan.style.cssText = 'flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;';
      nameSpan.title = att.name;

      var sizeSpan = document.createElement('span');
      sizeSpan.setAttribute('data-picker-ui', 'true');
      sizeSpan.textContent = humanAttachSize(att.size);
      sizeSpan.style.cssText = 'flex-shrink:0;font-size:11px;color:#64748b;';

      var removeBtn = document.createElement('button');
      removeBtn.setAttribute('data-picker-ui', 'true');
      removeBtn.setAttribute('aria-label', 'Remove ' + att.name);
      removeBtn.textContent = '×';
      removeBtn.style.cssText = [
        'background:none',
        'border:none',
        'color:#64748b',
        'cursor:pointer',
        'font-size:16px',
        'line-height:1',
        'padding:0',
        'flex-shrink:0',
      ].join(';');
      (function(idx) {
        removeBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          pendingAttachments.splice(idx, 1);
          renderAttachChips();
        });
      })(i);

      row.appendChild(icon);
      row.appendChild(nameSpan);
      row.appendChild(sizeSpan);
      row.appendChild(removeBtn);
      attachChipsContainer.appendChild(row);
    });
  }

  function updateAttachDropZone() {
    if (attachmentUploading) {
      attachDropZone.textContent = '⏳ Uploading…';
      attachDropZone.style.borderColor = '#6366f1';
      attachDropZone.style.color = '#6366f1';
      attachDropZone.style.cursor = 'not-allowed';
    } else {
      attachDropZone.textContent = '📎 Drop files or click to attach (max 10 MB)';
      attachDropZone.style.borderColor = '#475569';
      attachDropZone.style.color = '#94a3b8';
      attachDropZone.style.cursor = 'pointer';
    }
    attachFileInput.value = '';
  }

  function showAttachError(msg) {
    var prev = attachDropZone.textContent;
    attachDropZone.textContent = '⚠️ ' + msg;
    attachDropZone.style.color = '#ef4444';
    setTimeout(function() {
      attachDropZone.style.color = '#94a3b8';
      attachDropZone.textContent = prev !== attachDropZone.textContent ? '📎 Drop files or click to attach (max 10 MB)' : prev;
    }, 3000);
  }

  function doUploadAttachment(file) {
    if (!FEEDBACK_URL || FEEDBACK_URL === '__FEEDBACK_URL__') return;
    var MAX = 10 * 1024 * 1024;
    if (file.size > MAX) {
      showAttachError('"' + (file.name.length > 20 ? file.name.slice(0, 20) + '…' : file.name) + '" exceeds 10 MB');
      return;
    }
    attachmentUploading = true;
    updateAttachDropZone();
    var fd = new FormData();
    fd.append('file', file);
    fd.append('annotateToken', ANNOTATE_TOKEN);
    fetch(FEEDBACK_URL + '/upload', { method: 'POST', body: fd })
      .then(function(r) {
        return r.ok ? r.json() : r.json().then(function(e) { throw new Error(e.message || ('HTTP ' + r.status)); });
      })
      .then(function(att) {
        pendingAttachments.push(att);
        renderAttachChips();
      })
      .catch(function(err) {
        showAttachError('Upload failed: ' + err.message);
      })
      .then(function() {
        attachmentUploading = false;
        updateAttachDropZone();
      });
  }

  function doUploadFiles(files) {
    // Upload sequentially so each DB append sees the previous result
    Array.prototype.slice.call(files).reduce(function(chain, file) {
      return chain.then(function() { return doUploadAttachment(file); });
    }, Promise.resolve());
  }

  attachDropZone.addEventListener('click', function() {
    if (attachmentUploading) return;
    attachFileInput.click();
  });

  attachFileInput.addEventListener('change', function() {
    if (this.files && this.files.length) doUploadFiles(this.files);
    this.value = '';
  });

  attachDropZone.addEventListener('dragover', function(e) {
    e.preventDefault();
    e.stopPropagation();
    if (!attachmentUploading) {
      attachDropZone.style.borderColor = '#6366f1';
      attachDropZone.style.color = '#6366f1';
    }
  });

  attachDropZone.addEventListener('dragleave', function(e) {
    e.stopPropagation();
    if (!attachmentUploading) {
      attachDropZone.style.borderColor = '#475569';
      attachDropZone.style.color = '#94a3b8';
    }
  });

  attachDropZone.addEventListener('drop', function(e) {
    e.preventDefault();
    e.stopPropagation();
    if (!attachmentUploading) {
      attachDropZone.style.borderColor = '#475569';
      attachDropZone.style.color = '#94a3b8';
    }
    if (attachmentUploading) return;
    var files = e.dataTransfer && e.dataTransfer.files;
    if (files && files.length) doUploadFiles(files);
  });

  var feedbackBtnRow = document.createElement('div');
  feedbackBtnRow.setAttribute('data-picker-ui', 'true');
  feedbackBtnRow.style.cssText = 'display:flex;gap:8px';

  var feedbackBackBtn = document.createElement('button');
  feedbackBackBtn.id = 'pk-feedback-back-btn';
  feedbackBackBtn.setAttribute('data-picker-ui', 'true');
  feedbackBackBtn.textContent = '← Back';
  feedbackBackBtn.style.cssText = 'padding:7px 14px;background:#475569;color:#fff;border:none;border-radius:8px;font-size:13px;cursor:pointer;';

  var addToBatchBtn = document.createElement('button');
  addToBatchBtn.id = 'pk-add-to-batch-btn';
  addToBatchBtn.setAttribute('data-picker-ui', 'true');
  addToBatchBtn.textContent = 'Add to batch';
  addToBatchBtn.style.cssText = 'padding:7px 14px;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;';

  feedbackBtnRow.appendChild(feedbackBackBtn);
  feedbackBtnRow.appendChild(addToBatchBtn);
  feedbackSection.appendChild(feedbackSummary);
  feedbackSection.appendChild(feedbackTextarea);
  feedbackSection.appendChild(researchRow);
  feedbackSection.appendChild(attachChipsContainer);
  feedbackSection.appendChild(attachDropZone);
  feedbackSection.appendChild(attachFileInput);
  feedbackSection.appendChild(feedbackBtnRow);
  overlay.appendChild(feedbackSection);

  // ── Section: BATCH_REVIEW ─────────────────────────────────────────────────

  var batchReviewSection = document.createElement('div');
  batchReviewSection.id = 'pk-batchreview-section';
  batchReviewSection.setAttribute('data-picker-ui', 'true');
  batchReviewSection.style.display = 'none';

  var batchTitle = document.createElement('div');
  batchTitle.setAttribute('data-picker-ui', 'true');
  batchTitle.style.cssText = 'font-size:11px;color:#64748b;margin-bottom:6px';

  var batchListDiv = document.createElement('div');
  batchListDiv.id = 'pk-batch-list';
  batchListDiv.setAttribute('data-picker-ui', 'true');
  batchListDiv.style.cssText = 'max-height:160px;overflow-y:auto;';

  var batchBtnCol = document.createElement('div');
  batchBtnCol.setAttribute('data-picker-ui', 'true');
  batchBtnCol.style.cssText = 'margin-top:10px;display:flex;flex-direction:column;gap:8px';

  var addMoreBtn = document.createElement('button');
  addMoreBtn.id = 'pk-add-more-btn';
  addMoreBtn.setAttribute('data-picker-ui', 'true');
  addMoreBtn.textContent = '＋ Add more';
  addMoreBtn.style.cssText = 'padding:7px 14px;background:#475569;color:#fff;border:none;border-radius:8px;font-size:13px;cursor:pointer;width:100%';

  var sendAllBtn = document.createElement('button');
  sendAllBtn.id = 'pk-send-all-btn';
  sendAllBtn.setAttribute('data-picker-ui', 'true');
  sendAllBtn.textContent = 'Send All (0)';
  sendAllBtn.style.cssText = 'padding:7px 14px;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;width:100%';

  var cancelAllBtn = document.createElement('button');
  cancelAllBtn.id = 'pk-cancel-all-btn';
  cancelAllBtn.setAttribute('data-picker-ui', 'true');
  cancelAllBtn.textContent = 'Cancel all';
  cancelAllBtn.style.cssText = 'padding:7px 14px;background:rgba(239,68,68,0.12);color:#f87171;border:1px solid rgba(239,68,68,0.3);border-radius:8px;font-size:13px;cursor:pointer;width:100%';

  // Minimize: collapse the panel to the floating button while keeping queued drafts.
  var minimizeBtn = document.createElement('button');
  minimizeBtn.id = 'pk-minimize-btn';
  minimizeBtn.setAttribute('data-picker-ui', 'true');
  minimizeBtn.textContent = '▾ Minimize — keep drafts';
  minimizeBtn.style.cssText = 'padding:7px 14px;background:#334155;color:#cbd5e1;border:none;border-radius:8px;font-size:13px;cursor:pointer;width:100%';

  batchBtnCol.appendChild(addMoreBtn);
  batchBtnCol.appendChild(sendAllBtn);
  batchBtnCol.appendChild(minimizeBtn);
  batchBtnCol.appendChild(cancelAllBtn);

  var statusMsg = document.createElement('div');
  statusMsg.id = 'pk-status-msg';
  statusMsg.setAttribute('data-picker-ui', 'true');
  statusMsg.style.cssText = 'margin-top:8px;font-size:12px;color:#86efac;display:none';

  batchReviewSection.appendChild(batchTitle);
  batchReviewSection.appendChild(batchListDiv);
  batchReviewSection.appendChild(batchBtnCol);
  batchReviewSection.appendChild(statusMsg);
  overlay.appendChild(batchReviewSection);

  // ── Section: BROWSE ───────────────────────────────────────────────────────

  var browseSection = document.createElement('div');
  browseSection.id = 'pk-browse-section';
  browseSection.setAttribute('data-picker-ui', 'true');
  browseSection.style.display = 'none';

  var browseFilterRow = document.createElement('div');
  browseFilterRow.setAttribute('data-picker-ui', 'true');
  browseFilterRow.style.cssText = 'display:flex;align-items:center;gap:8px;margin-bottom:8px';

  var browseFilter = document.createElement('input');
  browseFilter.id = 'pk-browse-filter';
  browseFilter.type = 'text';
  browseFilter.placeholder = 'Filter by tag, id, class...';
  browseFilter.setAttribute('data-picker-ui', 'true');
  browseFilter.style.cssText = 'flex:1;background:#2a2a3e;color:#f5f5f7;border:1px solid #444;border-radius:8px;padding:6px 8px;font-size:12px;font-family:system-ui,sans-serif';

  var browseListDiv = document.createElement('div');
  browseListDiv.id = 'pk-browse-list';
  browseListDiv.setAttribute('data-picker-ui', 'true');
  browseListDiv.style.cssText = 'max-height:280px;overflow-y:auto;font-family:monospace;font-size:11px';

  var browseBackBtn = document.createElement('button');
  browseBackBtn.id = 'pk-browse-back-btn';
  browseBackBtn.setAttribute('data-picker-ui', 'true');
  browseBackBtn.textContent = '← Back';
  browseBackBtn.style.cssText = 'margin-top:8px;padding:6px 14px;background:#475569;color:#fff;border:none;border-radius:8px;font-size:12px;cursor:pointer';

  browseFilterRow.appendChild(browseFilter);
  browseSection.appendChild(browseFilterRow);
  browseSection.appendChild(browseListDiv);
  browseSection.appendChild(browseBackBtn);
  overlay.appendChild(browseSection);

  // ── Panel drag handle (inserted as first overlay child) ───────────────────
  // Gives the user a grab target to reposition the panel when content is tall.

  var panelDragHandle = document.createElement('div');
  panelDragHandle.setAttribute('data-picker-ui', 'true');
  panelDragHandle.style.cssText = [
    'margin:0 -16px 10px -16px',
    'padding:7px 0 6px',
    'text-align:center',
    'cursor:grab',
    'border-bottom:1px solid #2d2d3d',
    'border-radius:12px 12px 0 0',
    'color:#4a4a6a',
    'font-size:18px',
    'line-height:1',
    'user-select:none',
    '-webkit-user-select:none',
    'touch-action:none',  // required: tells browser we own this touch, prevents scroll interference
    'flex-shrink:0',
  ].join(';');
  panelDragHandle.textContent = '☰'; // ☰ three horizontal bars
  overlay.insertBefore(panelDragHandle, overlay.firstChild);

  // ── Helper functions ──────────────────────────────────────────────────────

  function isPickerUI(el) {
    var cur = el;
    while (cur) {
      if (cur.getAttribute && cur.getAttribute('data-picker-ui') === 'true') return true;
      cur = cur.parentElement;
    }
    return false;
  }

  function buildSelector(el) {
    var sel = el.tagName.toLowerCase();
    if (el.id) {
      sel += '#' + el.id;
    } else if (el.classList && el.classList.length > 0) {
      sel += '.' + el.classList[0];
    }
    return sel;
  }

  function getXPath(el) {
    if (el.id) {
      return '//*[@id="' + el.id + '"]';
    }
    var parts = [];
    var current = el;
    while (current && current.nodeType === 1) {
      var tag = current.tagName.toLowerCase();
      var parent = current.parentElement;
      if (!parent) {
        parts.unshift(tag);
        break;
      }
      var siblings = parent.children;
      var sameTagCount = 0;
      var posAmongSame = 1;
      for (var i = 0; i < siblings.length; i++) {
        if (siblings[i].tagName.toLowerCase() === tag) {
          sameTagCount++;
          if (siblings[i] === current) {
            posAmongSame = sameTagCount;
          }
        }
      }
      if (sameTagCount > 1) {
        parts.unshift(tag + '[' + posAmongSame + ']');
      } else {
        parts.unshift(tag);
      }
      current = parent;
    }
    return '/' + parts.join('/');
  }

  function getComputedProp(el, prop) {
    try {
      return window.getComputedStyle(el).getPropertyValue(prop) || '';
    } catch (e) {
      return '';
    }
  }

  function getCssVars(el) {
    var vars = [];
    var seen = {};
    try {
      var sheets = document.styleSheets;
      for (var si = 0; si < sheets.length; si++) {
        var rules;
        try { rules = sheets[si].cssRules; } catch(e) { continue; }
        if (!rules) continue;
        for (var ri = 0; ri < rules.length; ri++) {
          var rule = rules[ri];
          if (!rule.selectorText) continue;
          try {
            if (!el.matches(rule.selectorText)) continue;
          } catch(e) { continue; }
          var cssText = rule.style ? rule.style.cssText : '';
          var matches = cssText.match(/var\((--[a-z0-9-]+)/g) || [];
          for (var mi = 0; mi < matches.length; mi++) {
            var name = matches[mi].slice(4); // strip "var("
            if (!seen[name]) { seen[name] = true; vars.push(name); }
          }
        }
      }
    } catch(e) {}
    return vars;
  }

  function captureElement(el) {
    var rect = el.getBoundingClientRect();
    var classes = [];
    if (el.classList) {
      for (var i = 0; i < el.classList.length; i++) {
        classes.push(el.classList[i]);
      }
    }
    var data = {
      tag: el.tagName.toLowerCase(),
      id: el.id || '',
      classes: classes,
      selector: buildSelector(el),
      xpath: getXPath(el),
      outerHTML: (el.outerHTML || '').substring(0, 600),
      transform: getComputedProp(el, 'transform'),
      position: getComputedProp(el, 'position'),
      top: getComputedProp(el, 'top'),
      left: getComputedProp(el, 'left'),
      width: getComputedProp(el, 'width'),
      height: getComputedProp(el, 'height'),
      color: getComputedProp(el, 'color'),
      background: getComputedProp(el, 'background'),
      css_vars: getCssVars(el),
      rect: {
        x: Math.round(rect.x),
        y: Math.round(rect.y),
        w: Math.round(rect.width),
        h: Math.round(rect.height),
      },
    };

    // ── Enriched metadata (each emitted only when non-empty) ────────────────
    try {
      var testid = el.getAttribute('data-testid') || el.getAttribute('data-test') || '';
      if (testid) data.data_testid = testid;

      var ariaLabel = el.getAttribute('aria-label') || '';
      if (ariaLabel) data.aria_label = ariaLabel;

      var titleAttr = el.getAttribute('title') || '';
      if (titleAttr) data.title_attr = titleAttr;

      var text = (el.textContent || '').trim().replace(/\s+/g, ' ').slice(0, 120);
      if (text) data.text = text;

      // Angular component tag names walking UP from the element (nearest first),
      // including the element's own tag when it matches /^app-/. Max 6 entries.
      var ancestors = [];
      var node = el;
      while (node && node.tagName && ancestors.length < 6) {
        var t = node.tagName.toLowerCase();
        if (/^app-/.test(t)) ancestors.push(t);
        node = node.parentElement;
      }
      if (ancestors.length) data.ancestor_selectors = ancestors;

      // Forward-compat: future build step stamps [data-source-loc] on nodes.
      var sl = el.closest && el.closest('[data-source-loc]');
      if (sl) {
        var loc = sl.getAttribute('data-source-loc');
        if (loc) data.data_source_loc = loc;
      }
    } catch (ex) {}

    return data;
  }

  function stackItemLabel(el) {
    var tag = el.tagName.toLowerCase();
    if (el.id) return tag + '#' + el.id;
    if (el.classList && el.classList.length > 0) return tag + '.' + el.classList[0];
    return tag;
  }

  function clearHover() {
    if (hoveredEl) {
      hoveredEl.style.outline = '';
      hoveredEl = null;
    }
  }

  function clearStackHighlight() {
    if (stackHighlightedEl) {
      stackHighlightedEl.style.outline = '';
      stackHighlightedEl = null;
    }
  }

  function enterCrosshair() {
    document.body.style.cursor = 'crosshair';
    document.body.setAttribute('data-picker-active', 'true');
  }

  function exitCrosshair() {
    document.body.style.cursor = '';
    document.body.removeAttribute('data-picker-active');
    clearHover();
  }

  function clearSelectionOutlines() {
    for (var i = 0; i < pendingSelections.length; i++) {
      var el = pendingSelections[i]._el;
      if (el) el.style.outline = '';
    }
  }

  function getSelectionEl(i) {
    var s = pendingSelections[i];
    if (s && s._el && document.contains(s._el)) return s._el;
    return null;
  }

  // ── Feature 1: Preview outline helpers ────────────────────────────────────

  function clearPreview() {
    if (previewEl) {
      // Restore outline: if it's a selected element, keep green; otherwise clear
      var isSelected = pendingSelections.some(function (p) { return p._el === previewEl; });
      if (!isSelected) {
        previewEl.style.outline = '';
      } else {
        previewEl.style.outline = '2px solid #10b981';
      }
      previewEl = null;
    }
  }

  function setPreview(el) {
    clearPreview();
    if (el) {
      previewEl = el;
      previewEl.style.outline = '2px dashed #6366f1';
    }
  }

  // ── Feature 1: Commit click ────────────────────────────────────────────────

  function commitClick() {
    if (!lastClickPoint) {
      clickCount = 0;
      clickTimer = null;
      return;
    }
    var stack = document.elementsFromPoint(lastClickPoint.x, lastClickPoint.y);
    var filtered = stack.filter(function (el) {
      var tag = (el.tagName || '').toLowerCase();
      return !isPickerUI(el) && tag !== 'html' && tag !== 'body' && tag;
    });

    clearPreview();

    var idx = Math.min(clickCount - 1, filtered.length - 1);
    var targetEl = filtered[idx];

    clickCount = 0;
    clickTimer = null;

    if (!targetEl) return;

    var existingIdx = -1;
    for (var ii = 0; ii < pendingSelections.length; ii++) {
      if (pendingSelections[ii]._el === targetEl) { existingIdx = ii; break; }
    }
    if (existingIdx !== -1) {
      var removedEl = pendingSelections[existingIdx]._el;
      if (removedEl) removedEl.style.outline = '';
      pendingSelections.splice(existingIdx, 1);
      rebuildSelList();
      updateAddFeedbackBtn();
    } else {
      addSelection(targetEl);
    }
  }

  // ── Circled digit labels ───────────────────────────────────────────────────

  var CIRCLED = ['①', '②', '③', '④', '⑤', '⑥', '⑦', '⑧', '⑨'];

  function circledNum(n) {
    return n <= CIRCLED.length ? CIRCLED[n - 1] : '(' + n + ')';
  }

  // ── Section display helper ─────────────────────────────────────────────────

  var ALL_SECTIONS = ['pk-selecting-section', 'pk-stacknav-section', 'pk-feedback-section', 'pk-batchreview-section', 'pk-browse-section'];

  function showSection(id) {
    for (var i = 0; i < ALL_SECTIONS.length; i++) {
      var sec = document.getElementById(ALL_SECTIONS[i]);
      if (!sec) continue;
      if (ALL_SECTIONS[i] !== id) {
        sec.style.display = 'none';
      } else if (ALL_SECTIONS[i] === 'pk-selecting-section') {
        // Flex column so selList scrolls and buttons stay pinned at bottom
        sec.style.display = 'flex';
        sec.style.flexDirection = 'column';
        sec.style.flex = '1';
        sec.style.minHeight = '0';
        sec.style.overflow = 'hidden';
      } else {
        sec.style.display = 'block';
      }
    }
  }

  // ── Rebuild sel list ──────────────────────────────────────────────────────

  function rebuildSelList() {
    selList.innerHTML = '';
    for (var i = 0; i < pendingSelections.length; i++) {
      (function (idx) {
        var item = pendingSelections[idx];
        var row = document.createElement('div');
        row.setAttribute('data-picker-ui', 'true');
        row.style.cssText = 'display:flex;align-items:center;justify-content:space-between;font-family:monospace;font-size:11px;color:#86efac;margin-bottom:4px;';

        var label = document.createElement('span');
        label.setAttribute('data-picker-ui', 'true');
        label.textContent = circledNum(idx + 1) + ' ' + item.selector;
        label.style.cssText = 'flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-right:6px;';

        var rmBtn = document.createElement('button');
        rmBtn.setAttribute('data-picker-ui', 'true');
        rmBtn.textContent = '✕';
        rmBtn.style.cssText = 'background:none;border:none;color:#64748b;cursor:pointer;font-size:11px;padding:0 2px;flex-shrink:0;';
        rmBtn.addEventListener('click', function (e) {
          e.stopPropagation();
          var el = pendingSelections[idx]._el;
          if (el) el.style.outline = '';
          pendingSelections.splice(idx, 1);
          rebuildSelList();
          updateAddFeedbackBtn();
        });

        row.appendChild(label);
        row.appendChild(rmBtn);
        selList.appendChild(row);
      })(i);
    }
  }

  function updateAddFeedbackBtn() {
    addFeedbackBtn.disabled = pendingSelections.length === 0;
    addFeedbackBtn.style.opacity = pendingSelections.length === 0 ? '0.5' : '1';
  }

  // ── Feedback summary ──────────────────────────────────────────────────────

  function updateFeedbackSummary() {
    if (feedbackIsGeneral || pendingSelections.length === 0) {
      feedbackSummary.textContent = 'General note — not tied to a specific element';
      feedbackSummary.style.color = '#94a3b8';
    } else {
      var labels = pendingSelections.map(function(p){ return p.selector; }).join(', ');
      feedbackSummary.textContent = pendingSelections.length + ' element(s) selected: ' + labels;
      feedbackSummary.style.color = '#94a3b8';
    }
  }

  // ── Restore a batch item back into the editor ────────────────────────────
  // Re-queries the live DOM for each element (by id then selector) so outlines
  // are re-applied. Pre-populates feedbackTextarea with the saved feedback text.

  function _cloneBatchItem(item) {
    // Deep clone via JSON — batch items hold only serialisable data (no _el refs).
    return JSON.parse(JSON.stringify(item));
  }

  function _restoreAndEditBatchItem(idx) {
    var item = batchItems[idx];
    // Snapshot the original so cancelling the edit reverts it instead of deleting it.
    editingOriginal = { item: _cloneBatchItem(item), index: idx };
    batchItems.splice(idx, 1);

    // Re-query live DOM refs and apply outlines
    pendingSelections = (item.elements || []).map(function (cap) {
      var el = null;
      if (cap.id) el = document.getElementById(cap.id);
      if (!el && cap.selector) {
        try { el = document.querySelector(cap.selector); } catch (ex) {}
      }
      if (el) el.style.outline = '2px solid #10b981';
      var copy = {};
      for (var k in cap) copy[k] = cap[k];
      copy._el = el;
      return copy;
    });

    feedbackIsGeneral = item.type === 'general';

    // Restore this item's attachments so the user can see/remove them while editing.
    pendingAttachments = (item.attachments || []).slice();
    renderAttachChips();

    // Pre-fill textarea BEFORE transitionTo so the draft-preserve logic picks it up
    feedbackTextarea.value = item.feedback;

    transitionTo('FEEDBACK');

    // Restore research flag (transitionTo resets it to false)
    if (item.research) {
      feedbackResearch = true;
      researchCheckbox.checked = true;
      researchLabel.style.color = '#6366f1';
    }
  }

  // ── Rebuild batch list ────────────────────────────────────────────────────

  function rebuildBatchList() {
    batchListDiv.innerHTML = '';
    batchTitle.textContent = 'Batch — ' + batchItems.length + ' item' + (batchItems.length !== 1 ? 's' : '') + ':';
    sendAllBtn.textContent = 'Send All (' + batchItems.length + ')';

    for (var i = 0; i < batchItems.length; i++) {
      (function (idx) {
        var item = batchItems[idx];
        var isGeneral = item.type === 'general' || !item.elements || item.elements.length === 0;
        var elCount = item.elements ? item.elements.length : 0;
        var snippet = item.feedback.length > 40 ? item.feedback.substring(0, 40) + '...' : item.feedback;

        var row = document.createElement('div');
        row.setAttribute('data-picker-ui', 'true');
        row.style.cssText = 'display:flex;align-items:center;justify-content:space-between;font-size:11px;color:#94a3b8;margin-bottom:4px;border-radius:4px;padding:2px 4px;cursor:pointer;';
        row.addEventListener('mouseover', function () { row.style.background = 'rgba(255,255,255,0.05)'; });
        row.addEventListener('mouseout',  function () { row.style.background = ''; });
        row.addEventListener('click', function (e) { _restoreAndEditBatchItem(idx); });

        var label = document.createElement('span');
        label.setAttribute('data-picker-ui', 'true');
        var researchBadge = item.research ? '🔍 ' : '';
        if (isGeneral) {
          label.textContent = researchBadge + '📝 General — "' + snippet + '"';
        } else {
          var firstSel = elCount > 0 ? item.elements[0].selector : '?';
          label.textContent = researchBadge + '● ' + (elCount > 1 ? elCount + ' elements' : firstSel) + ' — "' + snippet + '"';
        }
        label.style.cssText = 'flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-right:6px;';

        var editBtn = document.createElement('button');
        editBtn.setAttribute('data-picker-ui', 'true');
        editBtn.textContent = '✎'; // ✎
        editBtn.title = 'Edit';
        editBtn.style.cssText = 'background:none;border:none;color:#94a3b8;cursor:pointer;font-size:11px;padding:0 3px;flex-shrink:0;';
        editBtn.addEventListener('click', function (e) {
          e.stopPropagation();
          _restoreAndEditBatchItem(idx);
        });

        var rmBtn = document.createElement('button');
        rmBtn.setAttribute('data-picker-ui', 'true');
        rmBtn.textContent = '✕';
        rmBtn.style.cssText = 'background:none;border:none;color:#64748b;cursor:pointer;font-size:11px;padding:0 2px;flex-shrink:0;';
        rmBtn.addEventListener('click', function (e) {
          e.stopPropagation();
          batchItems.splice(idx, 1);
          rebuildBatchList();
        });

        row.appendChild(label);
        row.appendChild(editBtn);
        row.appendChild(rmBtn);
        batchListDiv.appendChild(row);
      })(i);
    }
  }

  // ── addSelection ──────────────────────────────────────────────────────────

  function addSelection(el) {
    var data = captureElement(el);
    data._el = el;
    pendingSelections.push(data);
    el.style.outline = '2px solid #10b981';
    rebuildSelList();
    updateAddFeedbackBtn();
  }

  // ── buildStackNav ─────────────────────────────────────────────────────────

  function buildStackNav(filtered) {
    stackNavTitle.textContent = filtered.length + ' elements here — pick one:';
    stackList.innerHTML = '';
    stackElements = filtered;

    for (var j = 0; j < filtered.length; j++) {
      (function (idx, el) {
        var li = document.createElement('li');
        li.setAttribute('data-picker-ui', 'true');
        li.style.cssText = [
          'cursor:pointer',
          'padding:6px 8px',
          'border-radius:4px',
          'font-family:monospace',
          'font-size:11px',
          'color:#cbd5e1',
          'border-left:3px solid transparent',
        ].join(';');

        var labelText = stackItemLabel(el) + ' ';
        var dimSpan = document.createElement('span');
        dimSpan.setAttribute('data-picker-ui', 'true');
        dimSpan.style.cssText = 'color:#475569;';
        dimSpan.textContent = '(' + (idx + 1) + ' of ' + filtered.length + ')';

        li.appendChild(document.createTextNode(labelText));
        li.appendChild(dimSpan);

        li.addEventListener('mouseover', function (e) {
          e.stopPropagation();
          var items = stackList.querySelectorAll('li');
          for (var k = 0; k < items.length; k++) {
            items[k].style.borderLeftColor = 'transparent';
            items[k].style.background = '';
          }
          li.style.borderLeftColor = '#6366f1';
          li.style.background = 'rgba(255,255,255,0.07)';
          clearStackHighlight();
          stackHighlightedEl = el;
          stackHighlightedEl.style.outline = '2px solid #6366f1';
        });

        li.addEventListener('mouseout', function (e) {
          e.stopPropagation();
        });

        li.addEventListener('click', function (e) {
          e.stopPropagation();
          e.preventDefault();
          clearStackHighlight();
          addSelection(el);
          transitionTo('SELECTING_from_STACK');
        });

        stackList.appendChild(li);
      })(j, filtered[j]);
    }

    // Highlight first by default
    if (filtered.length > 0) {
      stackHighlightedEl = filtered[0];
      stackHighlightedEl.style.outline = '2px solid #6366f1';
      var firstLi = stackList.querySelector('li');
      if (firstLi) firstLi.style.borderLeftColor = '#6366f1';
    }
  }

  // ── Feature 2: triggerStackNav ────────────────────────────────────────────

  function triggerStackNav(x, y) {
    var stack = document.elementsFromPoint(x, y);
    var filtered = stack.filter(function (el) {
      var tag = (el.tagName || '').toLowerCase();
      return !isPickerUI(el) && tag !== 'html' && tag !== 'body' && tag;
    });

    if (filtered.length <= 1) {
      // Show small toast "Only one element here" if exactly 0 or 1
      // (simple implementation: just return silently for 0, brief outline for 1)
      return;
    }

    // Set flag to prevent subsequent click from triggering
    longPressFired = true;

    // Cancel any pending click timer and clear preview
    if (clickTimer) {
      clearTimeout(clickTimer);
      clickTimer = null;
    }
    clickCount = 0;
    clearPreview();

    transitionTo('STACK_NAV');
    buildStackNav(filtered);
  }

  // ── Feature 3: walkDOM and buildBrowseList ─────────────────────────────────

  function walkDOM(el, depth, results) {
    if (!el || !el.tagName) return;
    var tag = el.tagName.toLowerCase();
    if (['script', 'style', 'head', 'meta', 'link', 'noscript'].indexOf(tag) !== -1) return;
    if (isPickerUI(el)) return;
    if (tag !== 'html' && tag !== 'body') {
      results.push({el: el, depth: depth, tag: tag});
    }
    var children = el.children;
    for (var i = 0; i < children.length; i++) {
      walkDOM(children[i], depth + 1, results);
    }
  }

  function clearBrowseHover() {
    if (browseHoverEl) {
      var isSelected = pendingSelections.some(function (p) { return p._el === browseHoverEl; });
      if (!isSelected) {
        browseHoverEl.style.outline = '';
      } else {
        browseHoverEl.style.outline = '2px solid #10b981';
      }
      browseHoverEl = null;
    }
  }

  function buildBrowseList(filterText) {
    if (!browseCache) {
      browseCache = [];
      walkDOM(document.body, 0, browseCache);
    }

    var lowerFilter = filterText ? filterText.toLowerCase() : '';
    browseListDiv.innerHTML = '';

    for (var i = 0; i < browseCache.length; i++) {
      (function (entry) {
        var el = entry.el;
        var tag = entry.tag;
        var depth = entry.depth;

        var label = tag;
        if (el.id) label += '#' + el.id;
        else if (el.classList && el.classList.length > 0) label += '.' + el.classList[0];

        var textHint = '';
        if (!el.id && !(el.classList && el.classList.length > 0)) {
          var rawText = el.textContent ? el.textContent.trim() : '';
          if (rawText) textHint = rawText.substring(0, 25);
        }

        var searchStr = (label + ' ' + textHint).toLowerCase();
        if (lowerFilter && searchStr.indexOf(lowerFilter) === -1) return;

        var cs = window.getComputedStyle(el);
        var isHidden = cs.display === 'none' || cs.visibility === 'hidden' || cs.opacity === '0';
        var isSelected = pendingSelections.some(function (p) { return p._el === el; });

        var row = document.createElement('div');
        row.setAttribute('data-picker-ui', 'true');
        row.style.cssText = 'padding:3px 4px;cursor:pointer;padding-left:' + (depth * 10) + 'px;border-radius:3px;';

        var rowLabel = '';
        if (isSelected) rowLabel += '✓ ';
        rowLabel += label;

        var rowEl = document.createElement('span');
        rowEl.setAttribute('data-picker-ui', 'true');
        rowEl.textContent = rowLabel;

        if (isSelected) {
          rowEl.style.color = '#86efac';
        } else if (isHidden) {
          rowEl.style.cssText = 'color:#475569;font-style:italic';
        } else {
          rowEl.style.color = '#cbd5e1';
        }

        row.appendChild(rowEl);

        if (textHint) {
          var hintSpan = document.createElement('span');
          hintSpan.setAttribute('data-picker-ui', 'true');
          hintSpan.textContent = ' ' + textHint;
          hintSpan.style.cssText = 'color:#475569;margin-left:4px';
          row.appendChild(hintSpan);
        }

        if (isHidden) {
          var eyeSpan = document.createElement('span');
          eyeSpan.setAttribute('data-picker-ui', 'true');
          eyeSpan.textContent = ' 👁';
          row.appendChild(eyeSpan);
        }

        row.addEventListener('mouseover', function (e) {
          e.stopPropagation();
          clearBrowseHover();
          browseHoverEl = el;
          el.style.outline = '2px solid #6366f1';
          row.style.background = 'rgba(255,255,255,0.05)';
          el.scrollIntoView({block: 'nearest', behavior: 'smooth'});
        });

        row.addEventListener('mouseout', function (e) {
          e.stopPropagation();
          if (browseHoverEl === el) {
            clearBrowseHover();
          }
          row.style.background = '';
        });

        row.addEventListener('click', function (e) {
          e.stopPropagation();
          var selIdx = -1;
          for (var ii = 0; ii < pendingSelections.length; ii++) {
            if (pendingSelections[ii]._el === el) { selIdx = ii; break; }
          }
          if (selIdx !== -1) {
            var removedEl = pendingSelections[selIdx]._el;
            if (removedEl) removedEl.style.outline = '';
            pendingSelections.splice(selIdx, 1);
            rebuildSelList();
            updateAddFeedbackBtn();
          } else {
            addSelection(el);
          }
          buildBrowseList(filterText);
        });

        browseListDiv.appendChild(row);
      })(browseCache[i]);
    }
  }

  // ── Helper: restore both FABs to their idle state per widget mode ─────────
  // Called from IDLE and CANCEL_ALL. Resets _sessionConfig to ANNOTATE_CONFIG.

  function _restoreFABs() {
    // Show a draft-count badge on the idle button so minimized drafts stay discoverable.
    var _draftCount = batchItems.length;
    _sessionConfig.btn.textContent = _sessionConfig.idleLabel + (_draftCount > 0 ? ' (' + _draftCount + ')' : '');
    _sessionConfig.btn.style.background = _sessionConfig.idleColor;
    annotateBtn.style.display = (_resolvedMode === 'feedback-only' || _nativeAnnotate) ? 'none' : 'block';
    feedbackBtn.style.display = (_hasFeedbackUrl && _resolvedMode !== 'fix-only') ? 'block' : 'none';
    _sessionConfig = ANNOTATE_CONFIG;
    _activeBtn     = annotateBtn;
  }

  // ── State transition function ─────────────────────────────────────────────

  function transitionTo(newState) {
    if (newState === 'SELECTING') {
      state = 'SELECTING';
      // Hide the inactive FAB; show the active one as the Cancel button.
      // This prevents overlap when both FABs are in the same corner.
      var _inactiveBtn = (_sessionConfig === ANNOTATE_CONFIG) ? feedbackBtn : annotateBtn;
      _inactiveBtn.style.display = 'none';
      _sessionConfig.btn.textContent = '✖ Cancel';
      _sessionConfig.btn.style.background = '#475569';
      _sessionConfig.btn.style.display = 'block';
      pendingSelections = [];
      clearSelectionOutlines();
      rebuildSelList();
      showSection('pk-selecting-section');
      overlay.style.display = 'flex';
      enterCrosshair();
      updateAddFeedbackBtn();

    } else if (newState === 'IDLE') {
      state = 'IDLE';
      _restoreFABs();
      clearSelectionOutlines();
      pendingSelections = [];
      editingOriginal = null;
      feedbackIsGeneral = false;
      // Clean up pending click debounce
      if (clickTimer) { clearTimeout(clickTimer); clickTimer = null; }
      clickCount = 0;
      clearPreview();
      clearBrowseHover();
      browseCache = null;
      exitCrosshair();
      overlay.style.display = 'none';

    } else if (newState === 'STACK_NAV') {
      state = 'STACK_NAV';
      exitCrosshair();
      showSection('pk-stacknav-section');

    } else if (newState === 'SELECTING_from_STACK') {
      // STACK_NAV → SELECTING (after pick or back)
      state = 'SELECTING';
      clearStackHighlight();
      stackList.innerHTML = '';
      showSection('pk-selecting-section');
      enterCrosshair();
      rebuildSelList();

    } else if (newState === 'PAUSED') {
      // Suspend click capture so user can navigate to another SPA page.
      // pendingSelections is preserved in the closure; the overlay hides.
      state = 'PAUSED';
      exitCrosshair();
      clearPreview();
      if (clickTimer) { clearTimeout(clickTimer); clickTimer = null; }
      clickCount = 0;
      overlay.style.display = 'none';
      var _pauseCount = pendingSelections.length;
      _sessionConfig.btn.textContent = '▶ Resume (' + _pauseCount + ' selected)';
      _sessionConfig.btn.style.background = '#92400e';  // amber — signals paused state
      _sessionConfig.btn.style.display = 'block';

    } else if (newState === 'RESUME') {
      // Return from PAUSED — restore overlay and re-enter crosshair.
      // pendingSelections already contains items from before the pause.
      state = 'SELECTING';
      _sessionConfig.btn.textContent = '✖ Cancel';
      _sessionConfig.btn.style.background = '#475569';
      _sessionConfig.btn.style.display = 'block';
      overlay.style.display = 'flex';
      showSection('pk-selecting-section');
      rebuildSelList();
      enterCrosshair();
      updateAddFeedbackBtn();

    } else if (newState === 'FEEDBACK') {
      state = 'FEEDBACK';
      _sessionConfig.btn.style.display = 'none';
      exitCrosshair();
      // Populate summary
      updateFeedbackSummary();
      // NOTE: feedbackTextarea.value is intentionally NOT cleared here.
      // Draft text is preserved across FEEDBACK ↔ SELECTING back/forth.
      // Callers that need a clean slate (addToBatchBtn, generalNoteBtn)
      // clear it themselves after a successful add-to-batch.
      feedbackTextarea.style.border = '1px solid #444';
      feedbackResearch = false;
      researchCheckbox.checked = false;
      researchLabel.style.color = '#94a3b8';
      showSection('pk-feedback-section');
      setTimeout(function () { feedbackTextarea.focus(); }, 50);

    } else if (newState === 'FEEDBACK_back') {
      // FEEDBACK → SELECTING (back)
      state = 'SELECTING';
      _sessionConfig.btn.style.background = '#475569';
      _sessionConfig.btn.style.display = 'block';
      enterCrosshair();
      rebuildSelList();
      showSection('pk-selecting-section');

    } else if (newState === 'BATCH_REVIEW') {
      state = 'BATCH_REVIEW';
      _sessionConfig.btn.style.display = 'none';
      overlay.style.display = 'flex';  // ensure overlay is visible regardless of entry path
      clearSelectionOutlines();
      pendingSelections = [];
      rebuildBatchList();
      showSection('pk-batchreview-section');

    } else if (newState === 'BATCH_MORE') {
      // BATCH_REVIEW → SELECTING (add more)
      state = 'SELECTING';
      _sessionConfig.btn.textContent = '✖ Cancel';
      _sessionConfig.btn.style.background = '#475569';
      _sessionConfig.btn.style.display = 'block';
      pendingSelections = [];
      rebuildSelList();
      showSection('pk-selecting-section');
      enterCrosshair();
      updateAddFeedbackBtn();

    } else if (newState === 'CANCEL_ALL') {
      // BATCH_REVIEW → IDLE
      batchItems = [];
      editingOriginal = null;
      pendingAttachments = [];
      renderAttachChips();
      state = 'IDLE';
      _restoreFABs();
      overlay.style.display = 'none';

    } else if (newState === 'SENDING') {
      state = 'SENDING';
      sendAllBtn.disabled = true;
      addMoreBtn.disabled = true;
      cancelAllBtn.disabled = true;
      statusMsg.style.display = 'block';
      statusMsg.textContent = '⏳ Sending...';

      // Capture element selectors BEFORE fetch so we can blur them on success.
      var _sendSelectors = [];
      batchItems.forEach(function (b) {
        (b.elements || []).forEach(function (e) { if (e.selector) _sendSelectors.push(e.selector); });
      });

      var count = batchItems.length;
      var _isFeedback = (_sessionConfig === FEEDBACK_CONFIG);
      var url, payload;

      if (_isFeedback) {
        // Feedback mode — send each batch item as its own card (fan-out server-side).
        // Posts to FEEDBACK_URL (stored for review, does not trigger the agent).
        url = FEEDBACK_URL;
        payload = {
          annotateToken: ANNOTATE_TOKEN,
          batches: batchItems,  // each item carries its own .attachments
          pageUrl: window.location.href,
          route: window.location.pathname,
        };
      } else if (ANNOTATE_TOKEN === '__ANNOTATE_TOKEN__') {
        // Mockup mode: token not replaced — send raw batches to the local mockup BFF.
        url = ANNOTATE_URL;
        payload = {
          mockup_id: MOCKUP_ID,
          batches: batchItems,
          page_url: window.location.href,
        };
      } else {
        // Deployment mode: send raw batches for server-side processing.
        // The API ports _build_annotation_xml / _build_annotation_summary from the
        // pipeline approval_gate and converts batches → structured XML for the agent.
        url = ANNOTATE_URL;
        payload = {
          batches: batchItems,
          annotateToken: ANNOTATE_TOKEN,
          page_url: window.location.href,
        };
      }

      fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
        .then(function (res) { return res.json(); })
        .then(function () {
          batchItems = [];
          pendingAttachments = [];
          renderAttachChips();
          if (_isFeedback || _sendSelectors.length === 0) {
            // Feedback mode or no element selectors — brief success, back to IDLE.
            statusMsg.textContent = _isFeedback
              ? '💬 Feedback noted! Keep browsing and send more anytime.'
              : '✅ Submitted! Keep browsing and send more anytime.';
            statusMsg.style.display = 'block';
            sendAllBtn.disabled = true;
            addMoreBtn.disabled = true;
            cancelAllBtn.disabled = true;
            setTimeout(function () { transitionTo('IDLE'); }, 1500);
          } else {
            // Annotation mode: lock selected elements with a durable overlay and
            // poll until the build is ready AND its revision advances. The page
            // reloads automatically (cache-busted) when that happens.
            //
            // Read the CURRENT revision first so the poll can require a strictly
            // greater value — this prevents reloading onto stale content when the
            // status briefly reports build_ready before the new build is served.
            var _persistLock = function () {
              _writeBlurLock(_sendSelectors, revisionAtSubmit);
              _reapplyLockOverlays();
              statusMsg.textContent = '🤖 AI is updating the selected elements…';
              statusMsg.style.display = 'block';
              // Hide the panel and return to IDLE so the user can browse while
              // waiting — the overlay is the only visible lock.
              overlay.style.display = 'none';
              _restoreFABs();
              state = 'IDLE';
              _startBlurPoll();
            };
            fetch(STATUS_URL, { cache: 'no-store' })
              .then(function (r) { return r.json(); })
              .then(function (d) {
                revisionAtSubmit = (d && typeof d.revision === 'number') ? d.revision : revisionAtSubmit;
              })
              .catch(function () { /* keep last-known revisionAtSubmit (or 0) */ })
              .then(function () { _persistLock(); });
          }
        })
        .catch(function (err) {
          statusMsg.textContent = '⚠️ Error: ' + err.message;
          sendAllBtn.disabled = false;
          addMoreBtn.disabled = false;
          cancelAllBtn.disabled = false;
          state = 'BATCH_REVIEW';
        });
    }
  }

  // ── Drag-to-reposition (button + panel) ──────────────────────────────────
  //
  // makeDraggable() attaches Pointer Events drag behaviour to any button and
  // persists its position to localStorage under storageKey.  Returns the drag
  // state object so click handlers can check .wasDragged to suppress a
  // click-after-drag.
  //
  // Uses the Pointer Events API so finger-drag works on mobile without separate
  // touch handlers. setPointerCapture() routes all subsequent pointer events to
  // the element even when the pointer leaves it — no global document listeners
  // needed. touch-action:none (set on each button above) prevents the browser
  // from intercepting the touch for scroll before our handler fires.
  //
  // pointercancel fires when an OS event interrupts a touch gesture mid-drag
  // (incoming call, notification pull-down). Both pointerup and pointercancel
  // clean up state identically to avoid stuck-drag bugs.
  //
  // A drag is only recognised if the cursor moves > 5px — otherwise mouseup
  // is treated as a normal click so the open/close toggle still works.

  function makeDraggable(btn, storageKey) {
    var ds = { active: false, wasDragged: false, startX: 0, startY: 0, offsetX: 0, offsetY: 0 };

    // Restore saved position from a previous session
    try {
      var saved = localStorage.getItem(storageKey);
      if (saved) {
        var pos = JSON.parse(saved);
        btn.style.bottom = '';
        btn.style.right  = '';
        btn.style.top    = pos.top  + 'px';
        btn.style.left   = pos.left + 'px';
      }
    } catch (e) {}

    btn.addEventListener('pointerdown', function (e) {
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      btn.setPointerCapture(e.pointerId);
      ds.active     = true;
      ds.wasDragged = false;
      ds.startX     = e.clientX;
      ds.startY     = e.clientY;
      var rect = btn.getBoundingClientRect();
      ds.offsetX    = e.clientX - rect.left;
      ds.offsetY    = e.clientY - rect.top;
      e.preventDefault(); // prevent text selection while dragging
    });

    btn.addEventListener('pointermove', function (e) {
      if (!ds.active) return;
      var dx = e.clientX - ds.startX;
      var dy = e.clientY - ds.startY;
      if (!ds.wasDragged && Math.sqrt(dx * dx + dy * dy) < 5) return;
      ds.wasDragged = true;

      var margin  = 4;
      var newLeft = Math.max(margin, Math.min(e.clientX - ds.offsetX, window.innerWidth  - btn.offsetWidth  - margin));
      var newTop  = Math.max(margin, Math.min(e.clientY - ds.offsetY, window.innerHeight - btn.offsetHeight - margin));
      btn.style.bottom = '';
      btn.style.right  = '';
      btn.style.left   = newLeft + 'px';
      btn.style.top    = newTop  + 'px';

      // Reposition panel only if it's open and this is the FAB that owns the session
      if (overlay.style.display !== 'none' && btn === _activeBtn) _repositionPanel();
    });

    function _endDrag() {
      if (!ds.active) return;
      ds.active = false;
      if (ds.wasDragged) {
        try {
          var rect = btn.getBoundingClientRect();
          localStorage.setItem(storageKey, JSON.stringify({ top: rect.top, left: rect.left }));
        } catch (e) {}
      }
    }
    btn.addEventListener('pointerup',     _endDrag);
    btn.addEventListener('pointercancel', _endDrag);

    return ds;
  }

  var _annotateDrag = makeDraggable(annotateBtn, 'pk-btn-pos');
  var _feedbackDrag = makeDraggable(feedbackBtn, 'pk-feedback-btn-pos');

  // Independent panel drag state — tracks dragging the panel by its header,
  // separate from button drag so each can be repositioned independently.
  var _panelDrag = {
    active: false,
    wasMoved: false, // set after first manual drag; suppresses _repositionPanel
    startX: 0,
    startY: 0,
    startPanelLeft: 0,
    startPanelTop: 0,
  };

  // Restore saved panel position from previous session (if any)
  try {
    var _savedPanel = localStorage.getItem('pk-panel-pos');
    if (_savedPanel) {
      var _ppos = JSON.parse(_savedPanel);
      overlay.style.bottom = '';
      overlay.style.right  = '';
      overlay.style.top    = _ppos.top  + 'px';
      overlay.style.left   = _ppos.left + 'px';
      _panelDrag.wasMoved  = true;
    }
  } catch (e) {}

  // Restore paused selections after a hard navigation (full-page reload fallback).
  // For SPA route changes pendingSelections survives in the closure; this only
  // fires when a real page load destroys the JS context mid-pause.
  (function () {
    try {
      var _saved = sessionStorage.getItem('pk-paused-selections');
      if (!_saved) return;
      var _parsed = JSON.parse(_saved);
      if (_parsed.mockupId !== MOCKUP_ID) return;
      sessionStorage.removeItem('pk-paused-selections');
      // _el refs are invalid on the new page — null them out. A zero-selection pause is
      // valid: the user paused specifically to pick on this page.
      pendingSelections = (_parsed.selections || []).map(function (s) {
        return Object.assign({}, s, { _el: null });
      });
      // Re-enter PAUSED, reviving the SAME FAB that owned the session before the reload
      // so a feedback-mode pause resumes as feedback (and stays clickable).
      if (_parsed.sessionKind === 'feedback' && _hasFeedbackUrl && _resolvedMode !== 'fix-only') {
        _sessionConfig = FEEDBACK_CONFIG;
        _activeBtn = feedbackBtn;
      } else {
        _sessionConfig = ANNOTATE_CONFIG;
        _activeBtn = annotateBtn;
      }
      state = 'PAUSED';
      _sessionConfig.btn.textContent = '▶ Resume (' + pendingSelections.length + ' selected)';
      _sessionConfig.btn.style.background = '#92400e';
      _sessionConfig.btn.style.display = 'block';
    } catch (e) {}
  })();

  function _repositionPanel() {
    if (_panelDrag.wasMoved) return; // user manually positioned panel — respect it
    // Anchor to the FAB that opened the current session
    var btnRect = _activeBtn.getBoundingClientRect();
    var panelW  = 340;
    var panelH  = overlay.offsetHeight || 320;
    var margin  = 8;

    // Prefer placing the panel above the button; flip below if not enough room
    var top = btnRect.top - panelH - margin;
    if (top < margin) top = btnRect.bottom + margin;

    // Prefer aligning panel's right edge with button's right edge; clamp to viewport
    var left = btnRect.right - panelW;
    if (left < margin) left = margin;
    if (left + panelW > window.innerWidth - margin) left = window.innerWidth - panelW - margin;

    overlay.style.top    = top  + 'px';
    overlay.style.left   = left + 'px';
    overlay.style.bottom = '';
    overlay.style.right  = '';
  }

  // Panel drag handle — drag the open overlay independently of the button
  panelDragHandle.addEventListener('pointerdown', function (e) {
    if (e.pointerType === 'mouse' && e.button !== 0) return;
    panelDragHandle.setPointerCapture(e.pointerId);
    var panelRect = overlay.getBoundingClientRect();
    _panelDrag.active         = true;
    _panelDrag.startX         = e.clientX;
    _panelDrag.startY         = e.clientY;
    _panelDrag.startPanelLeft = panelRect.left;
    _panelDrag.startPanelTop  = panelRect.top;
    panelDragHandle.style.cursor = 'grabbing';
    e.preventDefault();
    e.stopPropagation();
  });

  panelDragHandle.addEventListener('pointermove', function (e) {
    if (!_panelDrag.active) return;
    var margin  = 4;
    var panelW  = overlay.offsetWidth  || 340;
    var panelH  = overlay.offsetHeight || 320;
    var newLeft = _panelDrag.startPanelLeft + (e.clientX - _panelDrag.startX);
    var newTop  = _panelDrag.startPanelTop  + (e.clientY - _panelDrag.startY);
    newLeft = Math.max(margin, Math.min(newLeft, window.innerWidth  - panelW - margin));
    newTop  = Math.max(margin, Math.min(newTop,  window.innerHeight - panelH - margin));
    overlay.style.bottom = '';
    overlay.style.right  = '';
    overlay.style.left   = newLeft + 'px';
    overlay.style.top    = newTop  + 'px';
    _panelDrag.wasMoved  = true;
  });

  function _endPanelDrag() {
    if (!_panelDrag.active) return;
    _panelDrag.active = false;
    panelDragHandle.style.cursor = 'grab';
    try {
      var pRect = overlay.getBoundingClientRect();
      localStorage.setItem('pk-panel-pos', JSON.stringify({ top: pRect.top, left: pRect.left }));
    } catch (e) {}
  }
  panelDragHandle.addEventListener('pointerup',     _endPanelDrag);
  panelDragHandle.addEventListener('pointercancel', _endPanelDrag);

  // Watch overlay visibility; reposition panel relative to _activeBtn on show
  new MutationObserver(function () {
    if (overlay.style.display !== 'none') _repositionPanel();
  }).observe(overlay, { attributes: true, attributeFilter: ['style'] });

  // ── Annotate button click ─────────────────────────────────────────────────

  annotateBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (_annotateDrag.wasDragged) return; // suppress click after drag
    if (state === 'IDLE') {
      _sessionConfig = ANNOTATE_CONFIG;
      _activeBtn     = annotateBtn;
      if (batchItems.length > 0) {
        transitionTo('BATCH_REVIEW');
      } else {
        transitionTo('SELECTING');
      }
    } else if (state === 'SELECTING') {
      // If there are already-batched items, cancel means "stop adding more, go back to batch"
      // not "abandon the entire session".
      if (batchItems.length > 0) {
        transitionTo('BATCH_REVIEW');
      } else {
        transitionTo('IDLE');
      }
    } else if (state === 'PAUSED') {
      transitionTo('RESUME');
    }
    // In other states, button is hidden — do nothing
  });

  // ── Feedback button — delegates to the shared annotate overlay ───────────
  // Sets _sessionConfig = FEEDBACK_CONFIG then enters the same SELECTING flow.
  // The only difference is at SENDING time (URL + payload + done text).

  feedbackBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (_feedbackDrag.wasDragged) return; // suppress click after drag
    if (state === 'PAUSED') { transitionTo('RESUME'); return; } // revive a paused feedback session
    if (state !== 'IDLE') return;         // already in a session
    _sessionConfig = FEEDBACK_CONFIG;
    _activeBtn     = feedbackBtn;
    if (batchItems.length > 0) {
      transitionTo('BATCH_REVIEW');
    } else {
      transitionTo('SELECTING');
    }
  });

  // ── SELECTING section buttons ─────────────────────────────────────────────

  addFeedbackBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (state !== 'SELECTING') return;
    if (pendingSelections.length === 0) return;
    feedbackIsGeneral = false;
    feedbackTextarea.placeholder = 'What should change about these elements?';
    transitionTo('FEEDBACK');
  });

  selCancelBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    // If there are already-batched items, go back to batch review rather than
    // abandoning the entire session. Only go IDLE on a genuinely fresh start.
    if (batchItems.length > 0) {
      transitionTo('BATCH_REVIEW');
    } else {
      transitionTo('IDLE');
    }
  });

  pauseNavBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (state !== 'SELECTING') return;
    transitionTo('PAUSED');
  });

  generalNoteBtn.addEventListener('click', function() {
    feedbackIsGeneral = true;
    state = 'FEEDBACK';
    _sessionConfig.btn.style.display = 'none';
    exitCrosshair();
    updateFeedbackSummary();
    // Draft text preserved — only clear after a successful add-to-batch.
    feedbackTextarea.style.border = '1px solid #444';
    feedbackResearch = false;
    researchCheckbox.checked = false;
    researchLabel.style.color = '#94a3b8';
    showSection('pk-feedback-section');
    feedbackTextarea.placeholder = 'General feedback about the overall design...';
    feedbackTextarea.focus();
  });

  // ── STACK_NAV section buttons ─────────────────────────────────────────────

  stackBackBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (state !== 'STACK_NAV') return;
    clearStackHighlight();
    stackList.innerHTML = '';
    showSection('pk-selecting-section');
    enterCrosshair();
    state = 'SELECTING';
  });

  // ── FEEDBACK section buttons ──────────────────────────────────────────────

  feedbackBackBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (state !== 'FEEDBACK') return;
    feedbackResearch = false;
    researchCheckbox.checked = false;
    researchLabel.style.color = '#94a3b8';
    // Revert-on-cancel: when editing an already-queued item, restore the original at
    // its prior index instead of discarding it, then return to the batch list.
    if (editingOriginal) {
      var _restoreAt = Math.min(editingOriginal.index, batchItems.length);
      batchItems.splice(_restoreAt, 0, editingOriginal.item);
      editingOriginal = null;
      feedbackTextarea.value = '';
      transitionTo('BATCH_REVIEW');
      return;
    }
    transitionTo('FEEDBACK_back');
  });

  addToBatchBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (state !== 'FEEDBACK') return;
    var rawFeedback = feedbackTextarea.value.trim();
    if (!rawFeedback) {
      feedbackTextarea.style.border = '1px solid #ef4444';
      feedbackTextarea.style.animation = 'pk-shake 0.3s ease';
      setTimeout(function () {
        feedbackTextarea.style.border = '1px solid #444';
        feedbackTextarea.style.animation = '';
      }, 600);
      return;
    }

    var researchFlagged = feedbackResearch;
    if (rawFeedback.toLowerCase().startsWith('/qr ')) {
      researchFlagged = true;
      rawFeedback = rawFeedback.slice(4).trim();
    }

    // Strip _el before storing
    function stripEl(p) {
      var copy = {};
      for (var k in p) {
        if (k !== '_el') copy[k] = p[k];
      }
      return copy;
    }

    var item = {
      feedback: rawFeedback,
      elements: feedbackIsGeneral ? [] : pendingSelections.map(stripEl),
      type: feedbackIsGeneral ? 'general' : 'elements',
      research: researchFlagged,
      attachments: pendingAttachments.slice(),  // snapshot — owned by this item only
    };
    if (editingOriginal) {
      // Committing an edit: replace at the original position to preserve order.
      var _insertAt = Math.min(editingOriginal.index, batchItems.length);
      batchItems.splice(_insertAt, 0, item);
      editingOriginal = null;
    } else {
      batchItems.push(item);
    }
    // Clear so the next item starts with no attachments.
    pendingAttachments = [];
    renderAttachChips();
    feedbackIsGeneral = false;
    feedbackResearch = false;
    researchCheckbox.checked = false;
    researchLabel.style.color = '#94a3b8';
    feedbackTextarea.value = '';  // clear draft only after a successful add
    transitionTo('BATCH_REVIEW');
  });

  // ── BATCH_REVIEW section buttons ──────────────────────────────────────────

  addMoreBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (state !== 'BATCH_REVIEW') return;
    transitionTo('BATCH_MORE');
  });

  sendAllBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (state !== 'BATCH_REVIEW') return;
    if (batchItems.length === 0) return;
    transitionTo('SENDING');
  });

  cancelAllBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (state !== 'BATCH_REVIEW') return;
    transitionTo('CANCEL_ALL');
  });

  minimizeBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (state !== 'BATCH_REVIEW') return;
    // Collapse to the floating button; batchItems are preserved (only Cancel all clears them).
    transitionTo('IDLE');
  });

  // ── Feature 3: Browse section buttons ─────────────────────────────────────

  browseBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (state !== 'SELECTING') return;
    exitCrosshair();
    browseCache = null;
    buildBrowseList('');
    showSection('pk-browse-section');
    setTimeout(function () { browseFilter.focus(); }, 50);
  });

  browseFilter.addEventListener('input', function () {
    buildBrowseList(this.value);
  });

  browseBackBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    clearBrowseHover();
    browseCache = null;
    showSection('pk-selecting-section');
    enterCrosshair();
  });

  // ── Mouseover / mouseout (only in SELECTING state) ────────────────────────

  document.addEventListener('mouseover', function (e) {
    if (state !== 'SELECTING') return;
    if (isPickerUI(e.target)) return;
    if (pendingSelections.some(function (p) { return p._el === e.target; })) return;
    clearHover();
    hoveredEl = e.target;
    hoveredEl.style.outline = '2px solid #6366f1';
  }, true);

  document.addEventListener('mouseout', function (e) {
    if (state !== 'SELECTING') return;
    if (isPickerUI(e.target)) return;
    if (hoveredEl === e.target) { clearHover(); }
  }, true);

  // ── Feature 1: Click handler with debounce ────────────────────────────────

  document.addEventListener('click', function (e) {
    if (state !== 'SELECTING') return;
    if (isPickerUI(e.target)) return;

    // Cancel any pending long-press — a click event means it was not a long-press
    if (longPressTimer) { clearTimeout(longPressTimer); longPressTimer = null; }

    // Feature 2: suppress click if long-press fired
    if (longPressFired) {
      longPressFired = false;
      e.preventDefault();
      e.stopPropagation();
      return;
    }

    e.preventDefault();
    e.stopPropagation();
    clearHover();

    clickCount++;
    lastClickPoint = {x: e.clientX, y: e.clientY};

    // Compute preview candidate
    var stack = document.elementsFromPoint(e.clientX, e.clientY);
    var filtered = stack.filter(function (el) {
      var tag = (el.tagName || '').toLowerCase();
      return !isPickerUI(el) && tag !== 'html' && tag !== 'body' && tag;
    });
    var previewIdx = Math.min(clickCount - 1, filtered.length - 1);
    if (filtered[previewIdx]) {
      setPreview(filtered[previewIdx]);
    }

    clearTimeout(clickTimer);
    clickTimer = setTimeout(commitClick, 400);
  }, true);

  // ── Feature 1: Suppress native double-click text selection ────────────────

  document.addEventListener('dblclick', function (e) {
    if (state === 'SELECTING') { e.preventDefault(); }
  }, true);

  // ── Feature 2: Mouse long-press ───────────────────────────────────────────

  document.addEventListener('mousedown', function (e) {
    if (state !== 'SELECTING') return;
    if (isPickerUI(e.target)) return;
    longPressPoint = {x: e.clientX, y: e.clientY};
    longPressTimer = setTimeout(function () {
      triggerStackNav(longPressPoint.x, longPressPoint.y);
    }, 400);
  }, true);

  document.addEventListener('mousemove', function (e) {
    if (!longPressTimer) return;
    var dx = e.clientX - longPressPoint.x;
    var dy = e.clientY - longPressPoint.y;
    if (Math.sqrt(dx * dx + dy * dy) > 5) {
      clearTimeout(longPressTimer);
      longPressTimer = null;
    }
  });

  document.addEventListener('mouseup', function (e) {
    if (longPressTimer) {
      clearTimeout(longPressTimer);
      longPressTimer = null;
    }
  }, true);

  // ── Feature 2: Touch long-press ───────────────────────────────────────────

  document.addEventListener('touchstart', function (e) {
    if (state !== 'SELECTING') return;
    if (isPickerUI(e.target)) return;
    var t = e.touches[0];
    longPressPoint = {x: t.clientX, y: t.clientY};
    longPressTimer = setTimeout(function () {
      triggerStackNav(longPressPoint.x, longPressPoint.y);
    }, 400);
  }, {passive: true});

  document.addEventListener('touchmove', function (e) {
    if (!longPressTimer) return;
    var t = e.touches[0];
    var dx = t.clientX - longPressPoint.x;
    var dy = t.clientY - longPressPoint.y;
    if (Math.sqrt(dx * dx + dy * dy) > 5) {
      clearTimeout(longPressTimer);
      longPressTimer = null;
    }
  }, {passive: true});

  document.addEventListener('touchend', function (e) {
    if (longPressTimer) {
      clearTimeout(longPressTimer);
      longPressTimer = null;
    }
  }, true);

  // ── Cross-page pause persistence (full-page reload fallback) ─────────────
  // For SPA (Angular) navigation pendingSelections survives in the closure;
  // this block only matters when a hard navigation (external link, refresh)
  // destroys the JS context while the user is in PAUSED state.

  window.addEventListener('beforeunload', function () {
    // Persist whenever paused — even with zero selections — because the whole point of
    // Pause is "navigate to another page THEN pick". Record which FAB owns the session
    // so the correct button (annotate vs feedback) is revived after a hard reload.
    if (state === 'PAUSED') {
      try {
        var _toStore = pendingSelections.map(function (p) {
          var copy = {};
          for (var k in p) { if (k !== '_el') copy[k] = p[k]; }
          return copy;
        });
        sessionStorage.setItem('pk-paused-selections', JSON.stringify({
          mockupId: MOCKUP_ID,
          sessionKind: (_sessionConfig === FEEDBACK_CONFIG) ? 'feedback' : 'annotate',
          selections: _toStore,
        }));
      } catch (e) {}
    } else {
      // Clear any stale paused state if navigating away without pause active
      try { sessionStorage.removeItem('pk-paused-selections'); } catch (e) {}
    }
  });

})();

</script>