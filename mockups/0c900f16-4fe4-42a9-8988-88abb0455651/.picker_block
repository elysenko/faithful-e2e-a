    } catch (e) {
    }
  }

  // src/drag/runtime.ts
  var DRAG_THRESHOLD_PX = 5;
  var FAB_DRAG_MARGIN = 4;
  var PANEL_DRAG_MARGIN = 4;
  var PANEL_ANCHOR_WIDTH = 340;
  var PANEL_ANCHOR_HEIGHT_FALLBACK = 320;
  var PANEL_ANCHOR_MARGIN = 8;
  function clampToViewport(left, top, width, height, margin) {
    return {
      left: Math.max(margin, Math.min(left, window.innerWidth - width - margin)),
      top: Math.max(margin, Math.min(top, window.innerHeight - height - margin))
    };
  }
  function createFabDragState() {
    return { active: false, wasDragged: false, startX: 0, startY: 0, offsetX: 0, offsetY: 0 };
  }
  function createPanelDragState() {
    return { active: false, wasMoved: false, startX: 0, startY: 0, startPanelLeft: 0, startPanelTop: 0 };
  }

  // src/drag/fab-drag.ts
  var ANNOTATE_BTN_POS_KEY = "pk-btn-pos";
  var FEEDBACK_BTN_POS_KEY = "pk-feedback-btn-pos";
  function restoreFabPosition(btn, storageKey2) {
    try {
      const saved = localStorage.getItem(storageKey2);
      if (saved) {
        const pos = JSON.parse(saved);
        const { left, top } = clampToViewport(pos.left, pos.top, btn.offsetWidth, btn.offsetHeight, FAB_DRAG_MARGIN);
        btn.style.bottom = "";
        btn.style.right = "";
        btn.style.top = top + "px";
        btn.style.left = left + "px";
      }
    } catch (e) {
    }
  }
  function makeDraggable(btn, storageKey2, deps) {
    const ds = createFabDragState();
    restoreFabPosition(btn, storageKey2);
    const onPointerDown = (e) => {
      if (e.pointerType === "mouse" && e.button !== 0) return;
      btn.setPointerCapture(e.pointerId);
      ds.active = true;
      ds.wasDragged = false;
      ds.startX = e.clientX;
      ds.startY = e.clientY;
      const rect = btn.getBoundingClientRect();
      ds.offsetX = e.clientX - rect.left;
      ds.offsetY = e.clientY - rect.top;
      e.preventDefault();
    };
    const onPointerMove = (e) => {
      if (!ds.active) return;
      const dx = e.clientX - ds.startX;
      const dy = e.clientY - ds.startY;
      if (!ds.wasDragged && Math.sqrt(dx * dx + dy * dy) < DRAG_THRESHOLD_PX) return;
      ds.wasDragged = true;
      const { left: newLeft, top: newTop } = clampToViewport(
        e.clientX - ds.offsetX,
        e.clientY - ds.offsetY,
        btn.offsetWidth,
        btn.offsetHeight,
        FAB_DRAG_MARGIN
      );
      btn.style.bottom = "";
      btn.style.right = "";
      btn.style.left = newLeft + "px";
      btn.style.top = newTop + "px";
      if (deps.isPanelOpen() && btn === deps.getActiveBtn()) deps.repositionPanel();
    };
    const endDrag = () => {
      if (!ds.active) return;
      ds.active = false;
      if (ds.wasDragged) {
        try {
          const rect = btn.getBoundingClientRect();
          const pos = { top: rect.top, left: rect.left };
          localStorage.setItem(storageKey2, JSON.stringify(pos));
        } catch (e) {
        }
      }
    };
    const onResize = () => {
      if (!btn.style.left && !btn.style.top) return;
      const rect = btn.getBoundingClientRect();
      const { left, top } = clampToViewport(rect.left, rect.top, btn.offsetWidth, btn.offsetHeight, FAB_DRAG_MARGIN);
      btn.style.left = left + "px";
      btn.style.top = top + "px";
      try {
        localStorage.setItem(storageKey2, JSON.stringify({ top, left }));
      } catch (e) {
      }
      if (deps.isPanelOpen() && btn === deps.getActiveBtn()) deps.repositionPanel();
    };
    btn.addEventListener("pointerdown", onPointerDown);
    btn.addEventListener("pointermove", onPointerMove);
    btn.addEventListener("pointerup", endDrag);
    btn.addEventListener("pointercancel", endDrag);
    window.addEventListener("resize", onResize);
    const dispose = () => {
      btn.removeEventListener("pointerdown", onPointerDown);
      btn.removeEventListener("pointermove", onPointerMove);
      btn.removeEventListener("pointerup", endDrag);
      btn.removeEventListener("pointercancel", endDrag);
      window.removeEventListener("resize", onResize);
    };
    return { state: ds, dispose };
  }

  // src/drag/panel-drag.ts
  var PANEL_POS_KEY = "pk-panel-pos";
  function restorePanelPosition(overlay, state) {
    try {
      const saved = localStorage.getItem(PANEL_POS_KEY);
      if (saved) {
        const pos = JSON.parse(saved);
        overlay.style.bottom = "";
        overlay.style.right = "";
        overlay.style.top = pos.top + "px";
        overlay.style.left = pos.left + "px";
        state.wasMoved = true;
        return true;
      }
    } catch (e) {
    }
    return false;
  }
  function repositionPanel(overlay, state, getActiveBtn) {
    if (state.wasMoved) return;
    const activeBtn = getActiveBtn();
    if (!activeBtn) return;
    const btnRect = activeBtn.getBoundingClientRect();
    const panelW = PANEL_ANCHOR_WIDTH;
    const panelH = overlay.offsetHeight || PANEL_ANCHOR_HEIGHT_FALLBACK;
    const margin = PANEL_ANCHOR_MARGIN;
    let top = btnRect.top - panelH - margin;
    if (top < margin) top = btnRect.bottom + margin;
    let left = btnRect.right - panelW;
    if (left < margin) left = margin;
    if (left + panelW > window.innerWidth - margin) left = window.innerWidth - panelW - margin;
    overlay.style.top = top + "px";
    overlay.style.left = left + "px";
    overlay.style.bottom = "";
    overlay.style.right = "";
  }
  function installPanelDrag(panelDragHandle, overlay, getActiveBtn, state = createPanelDragState()) {
    const onPointerDown = (e) => {
      if (e.pointerType === "mouse" && e.button !== 0) return;
      panelDragHandle.setPointerCapture(e.pointerId);
      const panelRect = overlay.getBoundingClientRect();
      state.active = true;
      state.startX = e.clientX;
      state.startY = e.clientY;
      state.startPanelLeft = panelRect.left;
      state.startPanelTop = panelRect.top;
      panelDragHandle.style.cursor = "grabbing";
      e.preventDefault();
      e.stopPropagation();
    };
    const onPointerMove = (e) => {
      if (!state.active) return;
      const margin = PANEL_DRAG_MARGIN;
      const panelW = overlay.offsetWidth || PANEL_ANCHOR_WIDTH;
      const panelH = overlay.offsetHeight || PANEL_ANCHOR_HEIGHT_FALLBACK;
      let newLeft = state.startPanelLeft + (e.clientX - state.startX);
      let newTop = state.startPanelTop + (e.clientY - state.startY);
      newLeft = Math.max(margin, Math.min(newLeft, window.innerWidth - panelW - margin));
      newTop = Math.max(margin, Math.min(newTop, window.innerHeight - panelH - margin));
      overlay.style.bottom = "";
      overlay.style.right = "";
      overlay.style.left = newLeft + "px";
      overlay.style.top = newTop + "px";
      state.wasMoved = true;
    };
    const endPanelDrag = () => {
      if (!state.active) return;
      state.active = false;
      panelDragHandle.style.cursor = "grab";
      try {
        const pRect = overlay.getBoundingClientRect();
        const pos = { top: pRect.top, left: pRect.left };
        localStorage.setItem(PANEL_POS_KEY, JSON.stringify(pos));
      } catch (e) {
      }
    };
    panelDragHandle.addEventListener("pointerdown", onPointerDown);
    panelDragHandle.addEventListener("pointermove", onPointerMove);
    panelDragHandle.addEventListener("pointerup", endPanelDrag);
    panelDragHandle.addEventListener("pointercancel", endPanelDrag);
    const observer = new MutationObserver(() => {
      if (overlay.style.display !== "none") repositionPanel(overlay, state, getActiveBtn);
    });
    observer.observe(overlay, { attributes: true, attributeFilter: ["style"] });
    const dispose = () => {
      panelDragHandle.removeEventListener("pointerdown", onPointerDown);
      panelDragHandle.removeEventListener("pointermove", onPointerMove);
      panelDragHandle.removeEventListener("pointerup", endPanelDrag);
      panelDragHandle.removeEventListener("pointercancel", endPanelDrag);
      observer.disconnect();
    };
    return { state, dispose };
  }

  // src/drag/restore.ts
  function restoreFabs(opts) {
    const {
      annotateBtn,
      feedbackBtn,
      annotateConfig,
      feedbackConfig,
      draftCount,
      resolvedMode,
      nativeAnnotate,
      hasFeedbackUrl: hasFeedbackUrl2
    } = opts;
    const badge = draftCount > 0 ? " (" + draftCount + ")" : "";
    annotateBtn.textContent = annotateConfig.idleLabel + badge;
    annotateBtn.style.background = annotateConfig.idleColor;
    feedbackBtn.textContent = feedbackConfig.idleLabel + badge;
    feedbackBtn.style.background = feedbackConfig.idleColor;
    annotateBtn.style.display = resolvedMode === "feedback-only" || nativeAnnotate ? "none" : "block";
    feedbackBtn.style.display = hasFeedbackUrl2 && resolvedMode !== "fix-only" ? "block" : "none";
    return { sessionConfig: annotateConfig, activeBtn: annotateBtn };
  }

  // src/state-machine.ts
  function restoreFabsFor(ctx) {
    const result = restoreFabs({
      annotateBtn: ctx.dom.annotateBtn,
      feedbackBtn: ctx.dom.feedbackBtn,
      annotateConfig: ctx.annotateConfig,
      feedbackConfig: ctx.feedbackConfig,
      draftCount: ctx.state.batchItems.length,
      resolvedMode: ctx.resolvedMode,
      nativeAnnotate: ctx.nativeAnnotate,
      hasFeedbackUrl: ctx.hasFeedbackUrl
    });
    ctx.sessionConfig = result.sessionConfig;
    ctx.activeBtn = result.activeBtn;
    ctx.state.sessionKind = "annotate";
  }
  function createTransitionTo(ctx, sendDeps) {
    const { dom, state } = ctx;
    return function transitionTo(newState) {
      if (newState === "SELECTING") {
        state.phase = "SELECTING";
        const inactiveBtn = ctx.sessionConfig === ctx.annotateConfig ? dom.feedbackBtn : dom.annotateBtn;
        inactiveBtn.style.display = "none";
        ctx.sessionConfig.btn.textContent = "\u2716 Cancel";
        ctx.sessionConfig.btn.style.background = "#475569";
        ctx.sessionConfig.btn.style.display = "block";
        state.pendingSelections = [];
        clearSelectionOutlines(state);
        rebuildSelList(dom, state);
        showSection("pk-selecting-section");
        dom.overlay.style.display = "flex";
        enterCrosshair();
        updateAddFeedbackBtn(dom, state);
      } else if (newState === "IDLE") {
        state.phase = "IDLE";
        restoreFabsFor(ctx);
        clearSelectionOutlines(state);
        state.pendingSelections = [];
        state.editingOriginal = null;
        state.feedbackIsGeneral = false;
        if (ctx.picking.clickTimer) {
          clearTimeout(ctx.picking.clickTimer);
          ctx.picking.clickTimer = null;
        }
        ctx.picking.clickCount = 0;
        clearPreview(state, ctx.picking);
        clearBrowseHover(state, ctx.picking);
        ctx.picking.browseCache = null;
        exitCrosshair(ctx.picking);
        dom.overlay.style.display = "none";
      } else if (newState === "STACK_NAV") {
        state.phase = "STACK_NAV";
        exitCrosshair(ctx.picking);
        showSection("pk-stacknav-section");
      } else if (newState === "SELECTING_from_STACK") {
        state.phase = "SELECTING";
        clearStackHighlight(ctx.picking);
        dom.stackList.innerHTML = "";
        showSection("pk-selecting-section");
        enterCrosshair();
        rebuildSelList(dom, state);
      } else if (newState === "PAUSED") {
        state.phase = "PAUSED";
        exitCrosshair(ctx.picking);
        clearPreview(state, ctx.picking);
        if (ctx.picking.clickTimer) {
          clearTimeout(ctx.picking.clickTimer);
          ctx.picking.clickTimer = null;
        }
        ctx.picking.clickCount = 0;
        dom.overlay.style.display = "none";
        const pauseCount = state.pendingSelections.length;
        ctx.sessionConfig.btn.textContent = "\u25B6 Resume (" + pauseCount + " selected)";
        ctx.sessionConfig.btn.style.background = "#92400e";
        ctx.sessionConfig.btn.style.display = "block";
      } else if (newState === "RESUME" || newState === "SELECTING_for_EDIT") {
        state.phase = "SELECTING";
        ctx.sessionConfig.btn.textContent = "\u2716 Cancel";
        ctx.sessionConfig.btn.style.background = "#475569";
        ctx.sessionConfig.btn.style.display = "block";
        dom.overlay.style.display = "flex";
        showSection("pk-selecting-section");
        rebuildSelList(dom, state);
        enterCrosshair();
        updateAddFeedbackBtn(dom, state);
      } else if (newState === "FEEDBACK") {
        state.phase = "FEEDBACK";
        ctx.sessionConfig.btn.style.display = "none";
        exitCrosshair(ctx.picking);
        updateFeedbackSummary(dom, state);
        dom.feedbackTextarea.style.border = "1px solid #444";
        if (state.editingOriginal) {
          dom.researchCheckbox.checked = state.feedbackResearch;
        } else {
          state.feedbackResearch = false;
          dom.researchCheckbox.checked = false;
        }
        showSection("pk-feedback-section");
        setTimeout(() => dom.feedbackTextarea.focus(), 50);
      } else if (newState === "FEEDBACK_back") {
        state.phase = "SELECTING";
        ctx.sessionConfig.btn.style.background = "#475569";
        ctx.sessionConfig.btn.style.display = "block";
        enterCrosshair();
        rebuildSelList(dom, state);
        showSection("pk-selecting-section");
      } else if (newState === "BATCH_REVIEW") {
        state.phase = "BATCH_REVIEW";
        ctx.sessionConfig.btn.style.display = "none";
        dom.overlay.style.display = "flex";
        clearSelectionOutlines(state);
        state.pendingSelections = [];
        rebuildBatchList(dom, state, { transitionTo: ctx.transitionTo });
        showSection("pk-batchreview-section");
      } else if (newState === "BATCH_MORE") {
        state.phase = "SELECTING";
        ctx.sessionConfig.btn.textContent = "\u2716 Cancel";
        ctx.sessionConfig.btn.style.background = "#475569";
        ctx.sessionConfig.btn.style.display = "block";
        state.pendingSelections = [];
        rebuildSelList(dom, state);
        showSection("pk-selecting-section");
        enterCrosshair();
        updateAddFeedbackBtn(dom, state);
      } else if (newState === "CANCEL_ALL") {
        state.batchItems = [];
        clearDraft();
        state.editingOriginal = null;
        state.pendingAttachments = [];
        renderAttachChips(dom, state);
        state.phase = "IDLE";
        restoreFabsFor(ctx);
        dom.overlay.style.display = "none";
      } else if (newState === "SENDING") {
        void sendAll(dom, state, sendDeps);
      }
    };
  }

  // src/state/pause.ts
  var PAUSE_STORAGE_KEY = "pk-paused-selections";
  function stripLiveRefs(state) {
    return state.pendingSelections.map((sel) => {
      const copy = __spreadValues({}, sel);
      delete copy._el;
      return copy;
    });
  }
  function serializePauseState(state, mockupId) {
    return {
      mockupId,
      sessionKind: state.sessionKind,
      selections: stripLiveRefs(state)
    };
  }
  function parsePausedRecord(raw, mockupId) {
    if (!raw) return null;
    let parsed;
    try {
      parsed = JSON.parse(raw);
    } catch (e) {
      return null;
    }
    if (!parsed || parsed.mockupId !== mockupId) return null;
    const sessionKind = parsed.sessionKind === "feedback" ? "feedback" : "annotate";
    return {
      mockupId,
      sessionKind,
      selections: Array.isArray(parsed.selections) ? parsed.selections : []
    };
  }
  function applyPausedRecord(state, record) {
    state.phase = "PAUSED";
    state.sessionKind = record.sessionKind;
    state.pendingSelections = record.selections.map((cap) => __spreadProps(__spreadValues({}, cap), { _el: null }));
  }

  // src/wiring-controls.ts
  function wireBrowse(ctx, pickingDeps) {
    const { dom, state } = ctx;
    dom.browseBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (state.phase !== "SELECTING") return;
      exitCrosshair(ctx.picking);
      ctx.picking.browseCache = null;
      buildBrowseList(dom, state, ctx.picking, pickingDeps, "");
      showSection("pk-browse-section");
      setTimeout(() => dom.browseFilter.focus(), 50);
    });
    dom.browseFilter.addEventListener("input", function() {
      buildBrowseList(dom, state, ctx.picking, pickingDeps, this.value);
    });
    dom.browseBackBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      clearBrowseHover(state, ctx.picking);
      ctx.picking.browseCache = null;
      showSection("pk-selecting-section");
      enterCrosshair();
    });
  }
  function wireDrag(ctx) {
    const { dom } = ctx;
    ctx.panelDrag = createPanelDragState();
    const getActiveBtn = () => ctx.activeBtn;
    const reposition = () => repositionPanel(dom.overlay, ctx.panelDrag, getActiveBtn);
    const isPanelOpen = () => dom.overlay.style.display !== "none";
    const annotate = makeDraggable(dom.annotateBtn, ANNOTATE_BTN_POS_KEY, {
      getActiveBtn,
      isPanelOpen,
      repositionPanel: reposition
    });
    const feedback = makeDraggable(dom.feedbackBtn, FEEDBACK_BTN_POS_KEY, {
      getActiveBtn,
      isPanelOpen,
      repositionPanel: reposition
    });
    ctx.annotateDrag = annotate.state;
    ctx.feedbackDrag = feedback.state;
    restorePanelPosition(dom.overlay, ctx.panelDrag);
    installPanelDrag(dom.panelDragHandle, dom.overlay, getActiveBtn, ctx.panelDrag);
  }
  function wireBlurLock(ctx) {
    installBlurNavListeners(ctx.blurLock);
    const blurDeps = { statusMsg: ctx.dom.statusMsg, buildSelector };
    restoreBlurLock(ctx.blurLock, blurDeps);
  }
  function wirePausePersistence(ctx) {
    window.addEventListener("beforeunload", () => {
      try {
        if (ctx.state.phase === "PAUSED") {
          const record = serializePauseState(ctx.state, ctx.mockupId);
          sessionStorage.setItem(PAUSE_STORAGE_KEY, JSON.stringify(record));
        } else {
          sessionStorage.removeItem(PAUSE_STORAGE_KEY);
        }
      } catch (e) {
      }
    });
  }

  // src/wiring.ts
  function wireFabs(ctx) {
    const { dom, state } = ctx;
    dom.annotateBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (ctx.annotateDrag && ctx.annotateDrag.wasDragged) return;
      if (state.phase === "IDLE") {
        ctx.sessionConfig = ctx.annotateConfig;
        ctx.activeBtn = dom.annotateBtn;
        state.sessionKind = "annotate";
        ctx.transitionTo(state.batchItems.length > 0 ? "BATCH_REVIEW" : "SELECTING");
      } else if (state.phase === "SELECTING") {
        if (state.editingOriginal) {
          cancelEdit(state);
          dom.feedbackTextarea.value = "";
          ctx.transitionTo("BATCH_REVIEW");
          return;
        }
        ctx.transitionTo(state.batchItems.length > 0 ? "BATCH_REVIEW" : "IDLE");
      } else if (state.phase === "PAUSED") {
        ctx.transitionTo("RESUME");
      }
    });
    dom.feedbackBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (ctx.feedbackDrag && ctx.feedbackDrag.wasDragged) return;
      if (state.phase === "PAUSED") {
        ctx.transitionTo("RESUME");
        return;
      }
      if (state.phase !== "IDLE") return;
      ctx.sessionConfig = ctx.feedbackConfig;
      ctx.activeBtn = dom.feedbackBtn;
      state.sessionKind = "feedback";
      ctx.transitionTo(state.batchItems.length > 0 ? "BATCH_REVIEW" : "SELECTING");
    });
  }
  function wireSelecting(ctx) {
    const { dom, state } = ctx;
    dom.addFeedbackBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (state.phase !== "SELECTING") return;
      if (state.pendingSelections.length === 0) return;
      state.feedbackIsGeneral = false;
      dom.feedbackTextarea.placeholder = "What should change about these elements?";
      ctx.transitionTo("FEEDBACK");
    });
    dom.selCancelBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (state.editingOriginal) {
        cancelEdit(state);
        dom.feedbackTextarea.value = "";
        ctx.transitionTo("BATCH_REVIEW");
        return;
      }
      ctx.transitionTo(state.batchItems.length > 0 ? "BATCH_REVIEW" : "IDLE");
    });
    dom.pauseNavBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (state.phase !== "SELECTING") return;
      ctx.transitionTo("PAUSED");
    });
    dom.generalNoteBtn.addEventListener("click", () => {
      state.feedbackIsGeneral = true;
      state.phase = "FEEDBACK";
      ctx.sessionConfig.btn.style.display = "none";
      exitCrosshair(ctx.picking);
      updateFeedbackSummary(dom, state);
      dom.feedbackTextarea.style.border = "1px solid #444";
      state.feedbackResearch = false;
      dom.researchCheckbox.checked = false;
      showSection("pk-feedback-section");
      dom.feedbackTextarea.placeholder = "General feedback about the overall design...";
      dom.feedbackTextarea.focus();
    });
  }
  function wireStackAndFeedback(ctx) {
    const { dom, state } = ctx;
    let addingToBatch = false;
    dom.stackBackBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (state.phase !== "STACK_NAV") return;
      clearStackHighlight(ctx.picking);
      dom.stackList.innerHTML = "";
      showSection("pk-selecting-section");
      enterCrosshair();
      state.phase = "SELECTING";
    });
    dom.feedbackBackBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (state.phase !== "FEEDBACK") return;
      state.feedbackResearch = false;
      dom.researchCheckbox.checked = false;
      if (state.editingOriginal) {
        cancelEdit(state);
        dom.feedbackTextarea.value = "";
        ctx.transitionTo("BATCH_REVIEW");
        return;
      }
      ctx.transitionTo("FEEDBACK_back");
    });
    dom.addToBatchBtn.addEventListener("click", async (e) => {
      e.stopPropagation();
      if (state.phase !== "FEEDBACK") return;
      const item = composeInProgressItem(dom, state);
      if (!item) {
        dom.feedbackTextarea.style.border = "1px solid #ef4444";
        dom.feedbackTextarea.style.animation = "pk-shake 0.3s ease";
        setTimeout(() => {
          dom.feedbackTextarea.style.border = "1px solid #444";
          dom.feedbackTextarea.style.animation = "";
        }, 600);
        return;
      }
      if (addingToBatch) return;
      addingToBatch = true;
      dom.addToBatchBtn.disabled = true;
      try {
        const shots = await freezeNoteScreenshots(state);
        if (shots.length) item.attachments.push(...shots);
        commitEdit(state, item);
        state.pendingAttachments = [];
        renderAttachChips(dom, state);
        state.feedbackIsGeneral = false;
        state.feedbackResearch = false;
        dom.researchCheckbox.checked = false;
        dom.feedbackTextarea.value = "";
        ctx.transitionTo("BATCH_REVIEW");
      } finally {
        addingToBatch = false;
        dom.addToBatchBtn.disabled = false;
      }
    });
  }
  function wireBatchReview(ctx) {
    const { dom, state } = ctx;
    dom.addMoreBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (state.phase !== "BATCH_REVIEW") return;
      ctx.transitionTo("BATCH_MORE");
    });
    dom.sendAllBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (state.phase !== "BATCH_REVIEW") return;
      if (state.batchItems.length === 0) return;
      ctx.transitionTo("SENDING");
    });
    dom.cancelAllBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (state.phase !== "BATCH_REVIEW") return;
      ctx.transitionTo("CANCEL_ALL");
    });
    dom.minimizeBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (state.phase !== "BATCH_REVIEW") return;
      ctx.transitionTo("IDLE");
    });
  }
  function installWiring(ctx, pickingDeps) {
    wireFabs(ctx);
    wireSelecting(ctx);
    wireStackAndFeedback(ctx);
    wireBatchReview(ctx);
    wireBrowse(ctx, pickingDeps);
    installHoverHandlers(document, ctx.state, ctx.picking);
    installClickHandlers(document, ctx.dom, ctx.state, ctx.picking, pickingDeps);
    installAttachmentHandlers(ctx.dom, ctx.state, ctx.attachments);
    wireDrag(ctx);
    wireBlurLock(ctx);
    wirePausePersistence(ctx);
  }

  // src/index.ts
  function readNativeCapabilities() {
    const caps = {};
    const meta = document.querySelector('meta[name="colossus-annotate"]');
    if (!meta) return caps;
    const list = (meta.getAttribute("content") || "").split(",");
    for (const raw of list) {
      const cap = raw.trim();
      if (cap) caps[cap] = true;
    }
    return caps;
  }
  function restorePausedSession(ctx) {
    try {
      const raw = sessionStorage.getItem(PAUSE_STORAGE_KEY);
      const record = parsePausedRecord(raw, ctx.mockupId);
      if (!record) return;
      sessionStorage.removeItem(PAUSE_STORAGE_KEY);
      applyPausedRecord(ctx.state, record);
      if (record.sessionKind === "feedback" && ctx.hasFeedbackUrl && ctx.resolvedMode !== "fix-only") {
        ctx.sessionConfig = ctx.feedbackConfig;
        ctx.activeBtn = ctx.dom.feedbackBtn;
      } else {
        ctx.sessionConfig = ctx.annotateConfig;
        ctx.activeBtn = ctx.dom.annotateBtn;
      }
      ctx.state.sessionKind = ctx.sessionConfig === ctx.feedbackConfig ? "feedback" : "annotate";
      const n = ctx.state.pendingSelections.length;
      ctx.sessionConfig.btn.textContent = "\u25B6 Resume (" + n + " selected)";
      ctx.sessionConfig.btn.style.background = "#92400e";
      ctx.sessionConfig.btn.style.display = "block";
    } catch (e) {
    }
  }
  function init() {
    const win = window;
    if (win.__COLOSSUS_PICKER_LOADED__) return;
    const nativeCaps = readNativeCapabilities();
    if (nativeCaps["annotate"] && nativeCaps["feedback"]) return;
    win.__COLOSSUS_PICKER_LOADED__ = true;
    const resolvedMode = resolveWidgetMode();
    const hasFeedbackUrl2 = hasFeedbackUrl();
    const nativeAnnotate = !!nativeCaps["annotate"];
    const dom = buildWidgetDom({ nativeAnnotate });
    const state = createWidgetState();
    initDraftStore(MOCKUP_ID);
    const restoredItems = loadDraft();
    if (restoredItems) state.batchItems = restoredItems;
    const annotateConfig = {
      btn: dom.annotateBtn,
      idleLabel: "\u270F\uFE0F Annotate",
      idleColor: "#6366f1"
    };
    const feedbackConfig = {
      btn: dom.feedbackBtn,
      idleLabel: "\u{1F4AC} Feedback",
      idleColor: "#10b981"
    };
    const ctx = {
      dom,
      state,
      resolvedMode,
      nativeAnnotate,
      hasFeedbackUrl: hasFeedbackUrl2,
      mockupId: MOCKUP_ID,
      annotateConfig,
      feedbackConfig,
      sessionConfig: annotateConfig,
      activeBtn: dom.annotateBtn,
      picking: createPickingRuntime(),
      attachments: createAttachmentRuntime(),
      blurLock: createBlurLockRuntime(),
      annotateDrag: null,
      feedbackDrag: null,
      panelDrag: null,
      transitionTo: () => void 0
      // assigned below
    };
    const blurDeps = { statusMsg: dom.statusMsg, buildSelector };
    const sendDeps = {
      transitionTo: (t) => ctx.transitionTo(t),
      // Legacy _persistLock (1890–1900): start the blur poll, then tear down the panel UI back to
      // IDLE so the user can browse while the overlay holds the lock.
      startBlurFlow: (selectors) => {
        void startBlurFlow(ctx.blurLock, blurDeps, selectors).then(() => {
          ctx.transitionTo("IDLE");
        });
      }
    };
    ctx.transitionTo = createTransitionTo(ctx, sendDeps);
    const pickingDeps = {
      rebuildSelList: () => rebuildSelList(dom, state),
      updateAddFeedbackBtn: () => updateAddFeedbackBtn(dom, state),
      transitionTo: (t) => ctx.transitionTo(t)
    };
    installWiring(ctx, pickingDeps);
    restorePausedSession(ctx);
    if (state.batchItems.length > 0 && state.phase !== "PAUSED") ctx.transitionTo("IDLE");
    window.addEventListener("pagehide", () => {
      const pending = composeInProgressItem(ctx.dom, ctx.state);
      if (pending) {
        if (ctx.state.editingOriginal) commitEdit(ctx.state, pending);
        else ctx.state.batchItems.push(pending);
        ctx.dom.feedbackTextarea.value = "";
        ctx.state.pendingSelections = [];
        ctx.state.pendingAttachments = [];
        ctx.state.feedbackIsGeneral = false;
        saveDraft(ctx.state);
      } else if (ctx.state.editingOriginal) {
        cancelEdit(ctx.state);
        saveDraft(ctx.state);
      }
      flushDraft();
    });
  }
  init();
})();

</script>