      renderAttachChips(dom, state);
      if (isFeedback || sendSelectors.length === 0) {
        dom.statusMsg.textContent = isFeedback ? "\u{1F4AC} Feedback noted! Keep browsing and send more anytime." : "\u2705 Submitted! Keep browsing and send more anytime.";
        dom.statusMsg.style.display = "block";
        dom.sendAllBtn.disabled = true;
        dom.addMoreBtn.disabled = true;
        dom.cancelAllBtn.disabled = true;
        setTimeout(() => deps.transitionTo("IDLE"), 1500);
      } else {
        deps.startBlurFlow(sendSelectors);
      }
    } catch (err) {
      dom.statusMsg.textContent = "\u26A0\uFE0F Error: " + err.message;
      dom.sendAllBtn.disabled = false;
      dom.addMoreBtn.disabled = false;
      dom.cancelAllBtn.disabled = false;
      state.phase = "BATCH_REVIEW";
    }
  }

  // src/blurlock/runtime.ts
  function createBlurLockRuntime() {
