        return {
          url: FEEDBACK_URL,
          headers: { "x-feedback-token": FEEDBACK_TOKEN },
          payload: { batches, pageUrl: loc.href, route: loc.pathname }
        };
      }
      return {
        url: FEEDBACK_URL,
        payload: { annotateToken: ANNOTATE_TOKEN, batches, pageUrl: loc.href, route: loc.pathname }
      };
    }
    if (isMockupMode()) {
      return {
        url: ANNOTATE_URL,
        payload: { mockup_id: MOCKUP_ID, batches, page_url: loc.href }
      };
    }
    return {
      url: ANNOTATE_URL,
      payload: { batches, annotateToken: ANNOTATE_TOKEN, page_url: loc.href }
    };
  }
  async function refreshAnnotateToken() {
    try {
      const overlayUrl = ANNOTATE_URL.replace(/\/annotate$/, "/overlay.js");
      if (overlayUrl === ANNOTATE_URL) return null;
      const txt = await fetch(overlayUrl, { cache: "no-store" }).then((r) => r.text());
      const m = txt.match(/annotateToken"\s*:\s*"([^"]+)"/);
