  // src/blurlock/poll.ts
  var POLL_INTERVAL_MS = 2e3;
  var SLOW_NOTICE_MS = 9e4;
  var HARD_CAP_MS = 3e5;
  var HARD_CAP_GUARD_MS = 299e3;
  var MANUAL_RELOAD_BTN_ID = "pk-manual-reload-btn";
  function stopBlurPoll(rt) {
    if (rt.pollTimer) {
      clearInterval(rt.pollTimer);
      rt.pollTimer = null;
    }
    if (rt.timeoutTimer) {
      clearTimeout(rt.timeoutTimer);
      rt.timeoutTimer = null;
    }
  }
  function ensureManualReloadBtn(deps) {
    if (document.getElementById(MANUAL_RELOAD_BTN_ID)) return;
    const btn = document.createElement("button");
    btn.id = MANUAL_RELOAD_BTN_ID;
    btn.setAttribute("data-picker-ui", "true");
    btn.textContent = "\u{1F504} Reload now";
    btn.style.cssText = "margin-top:6px;padding:5px 12px;background:#6366f1;color:#fff;border:none;border-radius:6px;font-size:12px;cursor:pointer;display:block;";
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      window.location.reload();
    });
    try {
      deps.statusMsg.appendChild(btn);
    } catch (e) {
    }
  }
  function startBlurPoll(rt, deps) {
    const started = Date.now();
    rt.pollTimer = setInterval(() => {
      fetch(STATUS_URL, { cache: "no-store" }).then((r) => r.json()).then((raw) => {
        const d = unwrapData(raw);
        if (!d) return;
        const revision = d.revision;
        if (d.annotationStatus === "build_ready" && typeof revision === "number" && revision > rt.revisionAtSubmit) {
          stopBlurPoll(rt);
          clearLockOverlays(rt);
          const sep = location.search ? location.search + "&" : "?";
          const dest = location.pathname + sep + "v=" + revision + (location.hash || "");
          window.location.href = dest;
        }
      }).catch(() => {
      });
    }, POLL_INTERVAL_MS);
    rt.timeoutTimer = setTimeout(() => {
      deps.statusMsg.textContent = "\u{1F916} Still building\u2026 (taking longer than usual)";
      deps.statusMsg.style.display = "block";
