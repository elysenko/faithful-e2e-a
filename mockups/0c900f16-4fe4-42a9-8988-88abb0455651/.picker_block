      deps.statusMsg.style.display = "block";
      ensureManualReloadBtn(deps);
    }, HARD_CAP_MS);
  }

  // src/blurlock/flow.ts
  function persistAndPoll(rt, deps, selectors) {
    writeBlurLock(selectors, rt.revisionAtSubmit);
    reapplyLockOverlays(rt);
    deps.statusMsg.textContent = "\u{1F916} AI is updating the selected elements\u2026";
    deps.statusMsg.style.display = "block";
