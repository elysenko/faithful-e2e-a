      clearHover(rt);
      rt.clickCount++;
      rt.lastClickPoint = { x: e.clientX, y: e.clientY };
      const filtered = pickableAtPoint(doc.elementsFromPoint(e.clientX, e.clientY));
      const previewIdx = stackIndexForClick(rt.clickCount, filtered.length);
      if (previewIdx >= 0 && filtered[previewIdx]) {
        setPreview(state, rt, filtered[previewIdx]);
      }
      if (rt.clickTimer) clearTimeout(rt.clickTimer);
      rt.clickTimer = setTimeout(() => commitClick(state, rt, deps), CLICK_DEBOUNCE_MS);
    };
    const onDblClick = (e) => {
      if (isSelecting(state)) e.preventDefault();
    };
    const onMouseDown = (e) => {
      if (!isSelecting(state)) return;
      if (isPickerUi(e.target)) return;
      rt.longPressPoint = { x: e.clientX, y: e.clientY };
      rt.longPressTimer = setTimeout(() => {
        if (rt.longPressPoint) triggerStackNav(dom, state, rt, deps, rt.longPressPoint.x, rt.longPressPoint.y);
      }, LONG_PRESS_MS);
    };
    const onMouseMove = (e) => {
      if (!rt.longPressTimer || !rt.longPressPoint) return;
      const dx = e.clientX - rt.longPressPoint.x;
      const dy = e.clientY - rt.longPressPoint.y;
      if (Math.sqrt(dx * dx + dy * dy) > LONG_PRESS_CANCEL_PX) {
        clearTimeout(rt.longPressTimer);
        rt.longPressTimer = null;
      }
    };
    const onMouseUp = () => {
      if (rt.longPressTimer) {
        clearTimeout(rt.longPressTimer);
        rt.longPressTimer = null;
      }
    };
    const onTouchStart = (e) => {
      if (!isSelecting(state)) return;
      if (isPickerUi(e.target)) return;
      const t = e.touches[0];
      rt.longPressPoint = { x: t.clientX, y: t.clientY };
      rt.longPressTimer = setTimeout(() => {
        if (rt.longPressPoint) triggerStackNav(dom, state, rt, deps, rt.longPressPoint.x, rt.longPressPoint.y);
      }, LONG_PRESS_MS);
    };
    const onTouchMove = (e) => {
      if (!rt.longPressTimer || !rt.longPressPoint) return;
      const t = e.touches[0];
      const dx = t.clientX - rt.longPressPoint.x;
      const dy = t.clientY - rt.longPressPoint.y;
      if (Math.sqrt(dx * dx + dy * dy) > LONG_PRESS_CANCEL_PX) {
        clearTimeout(rt.longPressTimer);
        rt.longPressTimer = null;
      }
    };
    const onTouchEnd = () => {
      if (rt.longPressTimer) {
        clearTimeout(rt.longPressTimer);
        rt.longPressTimer = null;
      }
    };
    doc.addEventListener("click", onClick, true);
    doc.addEventListener("dblclick", onDblClick, true);
    doc.addEventListener("mousedown", onMouseDown, true);
    doc.addEventListener("mousemove", onMouseMove);
    doc.addEventListener("mouseup", onMouseUp, true);
    doc.addEventListener("touchstart", onTouchStart, { passive: true });
    doc.addEventListener("touchmove", onTouchMove, { passive: true });
    doc.addEventListener("touchend", onTouchEnd, true);
    return () => {
      doc.removeEventListener("click", onClick, true);
      doc.removeEventListener("dblclick", onDblClick, true);
      doc.removeEventListener("mousedown", onMouseDown, true);
      doc.removeEventListener("mousemove", onMouseMove);
      doc.removeEventListener("mouseup", onMouseUp, true);
      doc.removeEventListener("touchstart", onTouchStart);
      doc.removeEventListener("touchmove", onTouchMove);
      doc.removeEventListener("touchend", onTouchEnd, true);
    };
  }

  // src/picking/browse.ts
  function clearBrowseHover(state, rt) {
    if (rt.browseHoverEl) {
      const isSelected = state.pendingSelections.some((p) => p._el === rt.browseHoverEl);
      rt.browseHoverEl.style.outline = isSelected ? OUTLINE_SELECTED : "";
      rt.browseHoverEl = null;
    }
  }
  function buildBrowseList(dom, state, rt, deps, filterText) {
    if (!rt.browseCache) {
      rt.browseCache = [];
      walkDOM(document.body, 0, rt.browseCache);
    }
    const lowerFilter = filterText ? filterText.toLowerCase() : "";
    dom.browseListDiv.innerHTML = "";
    for (let i = 0; i < rt.browseCache.length; i++) {
      const entry = rt.browseCache[i];
      const el2 = entry.el;
      const depth = entry.depth;
      const label = browseLabel(el2);
      const textHint = browseTextHint(el2);
      const searchStr = (label + " " + textHint).toLowerCase();
      if (lowerFilter && searchStr.indexOf(lowerFilter) === -1) continue;
      const cs = window.getComputedStyle(el2);
      const isHidden = cs.display === "none" || cs.visibility === "hidden" || cs.opacity === "0";
      const isSelected = state.pendingSelections.some((p) => p._el === el2);
      const row = document.createElement("div");
      markPickerUi(row);
      row.style.cssText = "padding:3px 4px;cursor:pointer;padding-left:" + depth * 10 + "px;border-radius:3px;";
      let rowLabel = "";
      if (isSelected) rowLabel += "\u2713 ";
      rowLabel += label;
      const rowEl = document.createElement("span");
      markPickerUi(rowEl);
      rowEl.textContent = rowLabel;
      if (isSelected) {
        rowEl.style.color = "#86efac";
      } else if (isHidden) {
        rowEl.style.cssText = "color:#475569;font-style:italic";
      } else {
        rowEl.style.color = "#cbd5e1";
      }
      row.appendChild(rowEl);
      if (textHint) {
        const hintSpan = document.createElement("span");
        markPickerUi(hintSpan);
        hintSpan.textContent = " " + textHint;
        hintSpan.style.cssText = "color:#475569;margin-left:4px";
        row.appendChild(hintSpan);
      }
      if (isHidden) {
        const eyeSpan = document.createElement("span");
        markPickerUi(eyeSpan);
        eyeSpan.textContent = " \u{1F441}";
        row.appendChild(eyeSpan);
      }
      row.addEventListener("mouseover", (e) => {
        e.stopPropagation();
        clearBrowseHover(state, rt);
        rt.browseHoverEl = el2;
        el2.style.outline = OUTLINE_HIGHLIGHT;
        row.style.background = "rgba(255,255,255,0.05)";
        el2.scrollIntoView({ block: "nearest", behavior: "smooth" });
      });
      row.addEventListener("mouseout", (e) => {
        e.stopPropagation();
        if (rt.browseHoverEl === el2) {
          clearBrowseHover(state, rt);
        }
        row.style.background = "";
      });
      row.addEventListener("click", (e) => {
        e.stopPropagation();
        let selIdx = -1;
        for (let ii = 0; ii < state.pendingSelections.length; ii++) {
          if (state.pendingSelections[ii]._el === el2) {
            selIdx = ii;
            break;
          }
        }
        if (selIdx !== -1) {
          const removedEl = state.pendingSelections[selIdx]._el;
          if (removedEl) removedEl.style.outline = "";
          state.pendingSelections.splice(selIdx, 1);
          deps.rebuildSelList();
          deps.updateAddFeedbackBtn();
        } else {
          addSelection(state, deps, el2);
        }
        buildBrowseList(dom, state, rt, deps, filterText);
      });
      dom.browseListDiv.appendChild(row);
    }
  }

  // src/feedback/attachments.ts
  function canUploadAttachments() {
    return hasFeedbackUrl() || isMockupMode();
  }
  var MAX_ATTACH_BYTES = 10 * 1024 * 1024;
  var DROPZONE_IDLE = "\u{1F4CE} Drop, paste, or click to attach (max 10 MB)";
  function createAttachmentRuntime() {
    return { uploading: false };
  }
  function humanAttachSize(bytes) {
    if (bytes < 1024) return bytes + " B";
    if (bytes < 1024 * 1024) return Math.round(bytes / 1024) + " KB";
    return (bytes / (1024 * 1024)).toFixed(1) + " MB";
  }
  function renderAttachChips(dom, state) {
    const container = dom.attachChipsContainer;
    container.innerHTML = "";
    if (state.pendingAttachments.length === 0) {
      container.style.display = "none";
      return;
    }
    container.style.display = "block";
    const header = document.createElement("div");
    header.setAttribute(PICKER_UI_ATTR, "true");
    header.style.cssText = "font-size:11px;color:#64748b;margin-bottom:4px;user-select:none;";
    header.textContent = "\u{1F4CE} Attached (" + state.pendingAttachments.length + "):";
    container.appendChild(header);
    state.pendingAttachments.forEach((att, i) => {
      const row = document.createElement("div");
      row.setAttribute(PICKER_UI_ATTR, "true");
      row.setAttribute("data-attach-name", att.name);
      row.style.cssText = [
        "display:flex",
        "align-items:center",
        "gap:6px",
        "background:rgba(99,102,241,.1)",
        "border:1px solid rgba(99,102,241,.3)",
        "border-radius:6px",
        "padding:4px 8px",
        "margin-bottom:3px",
        "font-size:12px",
        "color:#c4c4d4"
      ].join(";");
      const icon = document.createElement("span");
      icon.setAttribute(PICKER_UI_ATTR, "true");
      icon.textContent = "\u{1F4C4}";
      icon.style.cssText = "flex-shrink:0;font-size:13px;";
      const nameSpan = document.createElement("span");
      nameSpan.setAttribute(PICKER_UI_ATTR, "true");
      nameSpan.textContent = att.name.length > 28 ? att.name.slice(0, 28) + "\u2026" : att.name;
      nameSpan.style.cssText = "flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;";
      nameSpan.title = att.name;
      const sizeSpan = document.createElement("span");
      sizeSpan.setAttribute(PICKER_UI_ATTR, "true");
      sizeSpan.textContent = humanAttachSize(att.size);
      sizeSpan.style.cssText = "flex-shrink:0;font-size:11px;color:#64748b;";
      const removeBtn = document.createElement("button");
      removeBtn.setAttribute(PICKER_UI_ATTR, "true");
      removeBtn.setAttribute("aria-label", "Remove " + att.name);
      removeBtn.textContent = "\xD7";
      removeBtn.style.cssText = [
        "background:none",
        "border:none",
        "color:#64748b",
        "cursor:pointer",
        "font-size:16px",
        "line-height:1",
        "padding:0",
        "flex-shrink:0"
      ].join(";");
      removeBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        state.pendingAttachments.splice(i, 1);
        renderAttachChips(dom, state);
      });
      row.appendChild(icon);
      row.appendChild(nameSpan);
      row.appendChild(sizeSpan);
      row.appendChild(removeBtn);
      container.appendChild(row);
    });
  }
  function updateAttachDropZone(dom, rt) {
    const zone = dom.attachDropZone;
    if (rt.uploading) {
      zone.textContent = "\u23F3 Uploading\u2026";
      zone.style.borderColor = "#6366f1";
      zone.style.color = "#6366f1";
      zone.style.cursor = "not-allowed";
    } else {
      zone.textContent = DROPZONE_IDLE;
      zone.style.borderColor = "#475569";
      zone.style.color = "#94a3b8";
      zone.style.cursor = "pointer";
    }
    dom.attachFileInput.value = "";
  }
  function showAttachError(dom, msg) {
    const zone = dom.attachDropZone;
    const prev = zone.textContent;
    zone.textContent = "\u26A0\uFE0F " + msg;
    zone.style.color = "#ef4444";
    setTimeout(() => {
      zone.style.color = "#94a3b8";
      zone.textContent = prev !== zone.textContent ? DROPZONE_IDLE : prev;
    }, 3e3);
  }
  function doUploadAttachment(dom, state, rt, file) {
    if (!canUploadAttachments()) return Promise.resolve();
    if (file.size > MAX_ATTACH_BYTES) {
      const shortName = file.name.length > 20 ? file.name.slice(0, 20) + "\u2026" : file.name;
      showAttachError(dom, '"' + shortName + '" exceeds 10 MB');
      return Promise.resolve();
    }
    rt.uploading = true;
    updateAttachDropZone(dom, rt);
