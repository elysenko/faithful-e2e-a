    }).then(() => {
      rt.uploading = false;
      updateAttachDropZone(dom, rt);
    });
  }
  function doUploadFiles(dom, state, rt, files) {
    return Array.prototype.slice.call(files).reduce(
      (chain, file) => chain.then(() => doUploadAttachment(dom, state, rt, file)),
      Promise.resolve()
    );
  }
  function extractImageFiles(data, now = Date.now()) {
    if (!data || !data.items) return [];
    const out = [];
    Array.prototype.slice.call(data.items).forEach((item) => {
      if (item.kind !== "file" || !item.type.startsWith("image/")) return;
      const file = item.getAsFile();
      if (!file) return;
      const generic = !file.name || file.name === "image.png";
      if (!generic) {
        out.push(file);
        return;
      }
      const ext = item.type.split("/")[1] || "png";
      const suffix = out.length ? "-" + out.length : "";
      out.push(new File([file], `screenshot-${now}${suffix}.${ext}`, { type: item.type }));
    });
    return out;
  }
  function installAttachmentHandlers(dom, state, rt) {
    const zone = dom.attachDropZone;
    const input = dom.attachFileInput;
    dom.researchCheckbox.addEventListener("change", function() {
      state.feedbackResearch = this.checked;
    });
    dom.researchRow.addEventListener("click", (e) => {
      if (e.target !== dom.researchCheckbox) {
        dom.researchCheckbox.checked = !dom.researchCheckbox.checked;
        dom.researchCheckbox.dispatchEvent(new Event("change"));
      }
    });
    zone.addEventListener("click", () => {
      if (rt.uploading) return;
      input.click();
    });
    input.addEventListener("change", function() {
      if (this.files && this.files.length) doUploadFiles(dom, state, rt, this.files);
      this.value = "";
    });
    document.addEventListener("paste", (e) => {
      if (!dom.overlay.isConnected || dom.overlay.style.display === "none") return;
      if (rt.uploading) return;
