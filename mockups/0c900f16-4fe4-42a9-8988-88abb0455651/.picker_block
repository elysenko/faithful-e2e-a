  }
  async function sendAll(dom, state, deps) {
    state.phase = "SENDING";
    dom.sendAllBtn.disabled = true;
    dom.addMoreBtn.disabled = true;
    dom.cancelAllBtn.disabled = true;
    dom.statusMsg.style.display = "block";
    dom.statusMsg.textContent = "\u23F3 Sending...";
    const sendSelectors = [];
    state.batchItems.forEach((b) => {
      (b.elements || []).forEach((e) => {
        if (e.selector) sendSelectors.push(e.selector);
      });
    });
    const isFeedback = state.sessionKind === "feedback";
    const { url, payload, headers } = buildSendRequest(state);
    try {
      let res = await postSend(url, payload, headers);
      if (res.status === 401 && "annotateToken" in payload) {
        const fresh = await refreshAnnotateToken();
        if (fresh && fresh !== payload.annotateToken) {
          payload.annotateToken = fresh;
          res = await postSend(url, payload);
        }
      }
      if (!res.ok) {
        throw new Error(
          res.status === 401 ? "authentication expired \u2014 reload the page and try again" : `submit failed (HTTP ${res.status})`
        );
      }
      await res.json().catch(() => void 0);
      state.batchItems = [];
      state.pendingAttachments = [];
      discardEditSnapshot(state);
      clearDraft();
