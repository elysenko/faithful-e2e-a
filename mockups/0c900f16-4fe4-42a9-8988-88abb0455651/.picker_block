    zone.addEventListener("dragover", (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (!rt.uploading) {
        zone.style.borderColor = "#6366f1";
        zone.style.color = "#6366f1";
      }
    });
    zone.addEventListener("dragleave", (e) => {
      e.stopPropagation();
      if (!rt.uploading) {
        zone.style.borderColor = "#475569";
        zone.style.color = "#94a3b8";
      }
    });
    zone.addEventListener("drop", (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (!rt.uploading) {
        zone.style.borderColor = "#475569";
        zone.style.color = "#94a3b8";
      }
      if (rt.uploading) return;
      const files = e.dataTransfer && e.dataTransfer.files;
      if (files && files.length) doUploadFiles(dom, state, rt, files);
    });
  }

  // src/state/batch-edit.ts
  function beginEdit(state, index) {
    if (index < 0 || index >= state.batchItems.length) return null;
    const original = state.batchItems[index];
    state.editingOriginal = { item: cloneBatchItem(original), index };
    state.batchItems.splice(index, 1);
    return cloneBatchItem(original);
  }
  function cancelEdit(state) {
    const snapshot = state.editingOriginal;
    if (!snapshot) return;
    const insertAt = Math.min(snapshot.index, state.batchItems.length);
    state.batchItems.splice(insertAt, 0, snapshot.item);
    state.editingOriginal = null;
  }
  function commitEdit(state, edited) {
    const snapshot = state.editingOriginal;
    if (snapshot) {
      const insertAt = Math.min(snapshot.index, state.batchItems.length);
      state.batchItems.splice(insertAt, 0, edited);
      state.editingOriginal = null;
    } else {
      state.batchItems.push(edited);
    }
  }
  function discardEditSnapshot(state) {
    state.editingOriginal = null;
  }

  // src/state/draft.ts
  var DRAFT_STORAGE_KEY = "pk-draft-queue";
  var DRAFT_SCHEMA_VERSION = 1;
  var DRAFT_TTL_MS = 30 * 24 * 60 * 60 * 1e3;
  var SAVE_DEBOUNCE_MS = 500;
  function serializeDraft(state, mockupId, now) {
    return {
      v: DRAFT_SCHEMA_VERSION,
      mockupId,
      savedAt: now,
      items: state.batchItems
    };
  }
  function parseDraftRecord(raw, mockupId, now) {
    if (!raw) return null;
    let parsed;
    try {
      parsed = JSON.parse(raw);
    } catch (e) {
      return null;
    }
    if (!parsed || parsed.v !== DRAFT_SCHEMA_VERSION) return null;
    if (parsed.mockupId !== mockupId) return null;
    if (typeof parsed.savedAt !== "number" || now - parsed.savedAt > DRAFT_TTL_MS) return null;
    if (!Array.isArray(parsed.items) || parsed.items.length === 0) return null;
    return parsed.items;
  }
  var deploymentId = "";
  var saveTimer = null;
  var pendingState = null;
  function initDraftStore(mockupId) {
    deploymentId = mockupId;
  }
  function storageKey() {
    return DRAFT_STORAGE_KEY + ":" + deploymentId;
  }
  function flushPending() {
    if (saveTimer !== null) {
      clearTimeout(saveTimer);
      saveTimer = null;
    }
    const state = pendingState;
    pendingState = null;
    if (!state) return;
    try {
      if (state.batchItems.length === 0) {
        localStorage.removeItem(storageKey());
        return;
      }
      const record = serializeDraft(state, deploymentId, Date.now());
      localStorage.setItem(storageKey(), JSON.stringify(record));
    } catch (e) {
    }
  }
  function saveDraft(state) {
    pendingState = state;
    if (saveTimer !== null) clearTimeout(saveTimer);
    saveTimer = setTimeout(flushPending, SAVE_DEBOUNCE_MS);
  }
  function flushDraft() {
    if (pendingState !== null) flushPending();
  }
  function clearDraft() {
    if (saveTimer !== null) {
      clearTimeout(saveTimer);
      saveTimer = null;
    }
    pendingState = null;
    try {
      localStorage.removeItem(storageKey());
    } catch (e) {
    }
  }
  function loadDraft() {
    try {
      return parseDraftRecord(localStorage.getItem(storageKey()), deploymentId, Date.now());
    } catch (e) {
      return null;
    }
  }

  // src/feedback/render.ts
  var OUTLINE_SELECTED2 = "2px solid #10b981";
  var CIRCLED = ["\u2460", "\u2461", "\u2462", "\u2463", "\u2464", "\u2465", "\u2466", "\u2467", "\u2468"];
  var ALL_SECTIONS = [
    "pk-selecting-section",
    "pk-stacknav-section",
    "pk-feedback-section",
    "pk-batchreview-section",
    "pk-browse-section"
  ];
  function circledNum(n) {
    return n <= CIRCLED.length ? CIRCLED[n - 1] : "(" + n + ")";
  }
  function showSection(id) {
    for (let i = 0; i < ALL_SECTIONS.length; i++) {
      const sec = document.getElementById(ALL_SECTIONS[i]);
      if (!sec) continue;
      if (ALL_SECTIONS[i] !== id) {
        sec.style.display = "none";
      } else if (ALL_SECTIONS[i] === "pk-selecting-section") {
        sec.style.display = "flex";
        sec.style.flexDirection = "column";
        sec.style.flex = "1";
        sec.style.minHeight = "0";
        sec.style.overflow = "hidden";
      } else {
        sec.style.display = "block";
      }
    }
  }
  function rebuildSelList(dom, state) {
    dom.selList.innerHTML = "";
    for (let i = 0; i < state.pendingSelections.length; i++) {
      const idx = i;
      const item = state.pendingSelections[idx];
      const row = document.createElement("div");
      row.setAttribute(PICKER_UI_ATTR, "true");
      row.style.cssText = "display:flex;align-items:center;justify-content:space-between;font-family:monospace;font-size:11px;color:#86efac;margin-bottom:4px;";
      const unresolved = !item._el;
      const label = document.createElement("span");
      label.setAttribute(PICKER_UI_ATTR, "true");
      label.textContent = circledNum(idx + 1) + " " + item.selector + (unresolved ? "  \u26A0 open original page to edit" : "");
      if (unresolved) label.title = "This element is on another route \u2014 open that page to re-pick it.";
      label.style.cssText = "flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-right:6px;" + (unresolved ? "color:#94a3b8;font-style:italic;" : "");
      const rmBtn = document.createElement("button");
      rmBtn.setAttribute(PICKER_UI_ATTR, "true");
      rmBtn.textContent = "\u2715";
      rmBtn.style.cssText = "background:none;border:none;color:#64748b;cursor:pointer;font-size:11px;padding:0 2px;flex-shrink:0;";
      rmBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        const el2 = state.pendingSelections[idx]._el;
        if (el2) el2.style.outline = "";
        state.pendingSelections.splice(idx, 1);
        rebuildSelList(dom, state);
        updateAddFeedbackBtn(dom, state);
      });
      row.appendChild(label);
      row.appendChild(rmBtn);
      dom.selList.appendChild(row);
    }
  }
  function updateAddFeedbackBtn(dom, state) {
    const empty = state.pendingSelections.length === 0;
    dom.addFeedbackBtn.disabled = empty;
    dom.addFeedbackBtn.style.opacity = empty ? "0.5" : "1";
  }
  function updateFeedbackSummary(dom, state) {
    if (state.feedbackIsGeneral || state.pendingSelections.length === 0) {
      dom.feedbackSummary.textContent = "General note \u2014 not tied to a specific element";
      dom.feedbackSummary.style.color = "#94a3b8";
    } else {
      const labels = state.pendingSelections.map((p) => p.selector).join(", ");
      dom.feedbackSummary.textContent = state.pendingSelections.length + " element(s) selected: " + labels;
      dom.feedbackSummary.style.color = "#94a3b8";
    }
  }
  function restoreAndEditBatchItem(dom, state, deps, idx) {
    const edited = beginEdit(state, idx);
    if (!edited) return;
    state.pendingSelections = (edited.elements || []).map((cap) => {
      let el2 = null;
      if (cap.id) el2 = document.getElementById(cap.id);
      if (!el2 && cap.selector) {
        try {
          el2 = document.querySelector(cap.selector);
        } catch (e) {
        }
      }
      if (el2) el2.style.outline = OUTLINE_SELECTED2;
      return __spreadProps(__spreadValues({}, cap), { _el: el2 });
    });
    state.feedbackIsGeneral = edited.type === "general";
    state.feedbackResearch = !!edited.research;
    dom.researchCheckbox.checked = !!edited.research;
    state.pendingAttachments = (edited.attachments || []).slice();
    renderAttachChips(dom, state);
    dom.feedbackTextarea.value = edited.feedback;
    const hasElements = edited.type !== "general" && (edited.elements || []).length > 0;
    deps.transitionTo(hasElements ? "SELECTING_for_EDIT" : "FEEDBACK");
  }
  function rebuildBatchList(dom, state, deps) {
    dom.batchListDiv.innerHTML = "";
    const n = state.batchItems.length;
    dom.batchTitle.textContent = "Batch \u2014 " + n + " item" + (n !== 1 ? "s" : "") + ":";
    dom.sendAllBtn.textContent = "Send All (" + n + ")";
    dom.sendAllBtn.disabled = n === 0;
    dom.addMoreBtn.disabled = false;
    dom.cancelAllBtn.disabled = false;
    for (let i = 0; i < n; i++) {
      const idx = i;
      const item = state.batchItems[idx];
      const isGeneral = item.type === "general" || !item.elements || item.elements.length === 0;
      const elCount = item.elements ? item.elements.length : 0;
      const snippet = item.feedback.length > 40 ? item.feedback.substring(0, 40) + "..." : item.feedback;
      const row = document.createElement("div");
      row.setAttribute(PICKER_UI_ATTR, "true");
      row.style.cssText = "display:flex;align-items:center;justify-content:space-between;font-size:11px;color:#94a3b8;margin-bottom:4px;border-radius:4px;padding:2px 4px;cursor:pointer;";
      row.addEventListener("mouseover", () => {
        row.style.background = "rgba(255,255,255,0.05)";
      });
      row.addEventListener("mouseout", () => {
        row.style.background = "";
      });
      row.addEventListener("click", () => restoreAndEditBatchItem(dom, state, deps, idx));
      const label = document.createElement("span");
      label.setAttribute(PICKER_UI_ATTR, "true");
      const researchBadge = item.research ? "\u{1F50D} " : "";
      if (isGeneral) {
        label.textContent = researchBadge + '\u{1F4DD} General \u2014 "' + snippet + '"';
      } else {
        const firstSel = elCount > 0 ? item.elements[0].selector : "?";
        label.textContent = researchBadge + "\u25CF " + (elCount > 1 ? elCount + " elements" : firstSel) + ' \u2014 "' + snippet + '"';
      }
      label.style.cssText = "flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-right:6px;";
      const editBtn = document.createElement("button");
      editBtn.setAttribute(PICKER_UI_ATTR, "true");
      editBtn.textContent = "\u270E";
      editBtn.title = "Edit";
      editBtn.style.cssText = "background:none;border:none;color:#94a3b8;cursor:pointer;font-size:11px;padding:0 3px;flex-shrink:0;";
      editBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        restoreAndEditBatchItem(dom, state, deps, idx);
      });
      const rmBtn = document.createElement("button");
      rmBtn.setAttribute(PICKER_UI_ATTR, "true");
      rmBtn.textContent = "\u2715";
      rmBtn.style.cssText = "background:none;border:none;color:#64748b;cursor:pointer;font-size:11px;padding:0 2px;flex-shrink:0;";
      rmBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        state.batchItems.splice(idx, 1);
        rebuildBatchList(dom, state, deps);
      });
      row.appendChild(label);
      row.appendChild(editBtn);
      row.appendChild(rmBtn);
      dom.batchListDiv.appendChild(row);
    }
    saveDraft(state);
  }

  // src/feedback/send.ts
  function stripEl(p) {
    const copy = {};
    for (const k in p) {
      if (k !== "_el") copy[k] = p[k];
    }
    return copy;
  }
  function composeInProgressItem(dom, state) {
    let raw = dom.feedbackTextarea.value.trim();
    if (!raw) return null;
    let research = state.feedbackResearch;
    if (raw.toLowerCase().startsWith("/qr ")) {
      research = true;
      raw = raw.slice(4).trim();
    }
    if (!raw) return null;
    return {
      feedback: raw,
      elements: state.feedbackIsGeneral ? [] : state.pendingSelections.map((p) => stripEl(p)),
      type: state.feedbackIsGeneral ? "general" : "elements",
      research,
      attachments: state.pendingAttachments.slice(),
      // Route where these elements were selected (same key the selection screenshot is
      // tagged with), so the server attaches each route screenshot only to its own card.
      route: currentRouteKey(),
      // T6: KIND + must-contain/must-not-contain oracle hints
      kind: state.feedbackKind || void 0,
      mustContain: state.feedbackMustContain || void 0,
      mustNotContain: state.feedbackMustNotContain || void 0
    };
  }
  function sanitizeBatches(items) {
    return items.map((item) => __spreadProps(__spreadValues({}, item), {
      elements: (item.elements || []).map((el2) => stripEl(el2))
    }));
  }
  function buildSendRequest(state, loc = window.location) {
    const batches = sanitizeBatches(state.batchItems);
    if (state.sessionKind === "feedback") {
